    const opt = document.createElement('option');
    opt.value = tipo.id; opt.textContent = tipo.nome;
    sel.insertBefore(opt, sel.querySelector('option[value="outro"]'));
  }
}
function initCustomTipos() {
  loadCustomTipos().forEach(addCustomTipoToSidebar);
}
function getTipoLabel(tipoId) {
