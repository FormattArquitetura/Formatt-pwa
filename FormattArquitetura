/* ══ MODAL ══ */
let _modalSave = null, _modalDel = null;

function openModal(title, bodyHtml, onSave, onDel) {
 document.getElementById('inst-modal-title').textContent = title;
 document.getElementById('modal-body').innerHTML = bodyHtml;
 document.getElementById('inst-modal-delete-btn').style.display = onDel ? 'block' : 'none';
 _modalSave = onSave; _modalDel = onDel;
 document.getElementById('modal').classList.add('open');
}
function closeModal() { document.getElementById('modal').classList.remove('open'); }
function modalDelete() { if(_modalDel) _modalDel(); }

function val(id) { return document.getElementById(id)?.value || ''; }

/* ── EDITAR CAMPO SIMPLES ── */
function editCampo(campo, label, valorAtual) {
 const isTextarea = ['missao','visao','valores','endereco'].includes(campo);
 openModal('Editar ' + label,
 `<div class="field">
 <label class="field-label">${label}</label>
 ${isTextarea
 ? `<textarea class="field-input field-textarea" id="edit-val">${valorAtual}</textarea>`
 : `<input class="field-input" id="edit-val" value="${valorAtual}" placeholder="${label}">`}
 </div>
 <button class="save-btn" onclick="_saveModal()"> Salvar</button>`,
 () => {
 const e = load(KEYS.empresa)||{};
 e[campo] = val('edit-val');
 save(KEYS.empresa, e);
 closeModal();
 renderEmpresa();
 }
 );
}

