/* ── Gráfico A Pagar: despesas por vencimento ── */
function renderChartPagar() {
  const meses = agruparPorMes(getPagar(), 'data', 6);
  drawLineChart('chart-pagar', [
    { label: 'A pagar', data: meses.map(m => m.total), color: '#B05A3A' },
  ], meses.map(m => m.label));
  document.getElementById('chart-pagar-legend').innerHTML =
    '<div class="chart-leg-item"><div class="chart-leg-dot" style="background:#B05A3A;"></div>Despesas por mês</div>';
}

function fmtDateShort(d) {
  if (!d) return '';
  return new Date(d + 'T12:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short'});
}

