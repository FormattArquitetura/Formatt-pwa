/* ── CANVAS HELPERS ── */
function setupCanvas(id,H){
  const c=document.getElementById(id); if(!c)return null;
  const dpr=window.devicePixelRatio||1;
  const W=c.parentElement.clientWidth-28;
  c.width=W*dpr; c.height=H*dpr;
  c.style.width=W+'px'; c.style.height=H+'px';
  const ctx=c.getContext('2d'); ctx.scale(dpr,dpr);
  return {ctx,W,H,dpr};
}

function drawLine(id,datasets,labels,H=180){
  const s=setupCanvas(id,H); if(!s)return;
  const {ctx,W}=s;
  const PAD={top:16,right:16,bottom:32,left:52};
  const cW=W-PAD.left-PAD.right, cH=H-PAD.top-PAD.bottom;
  const all=datasets.flatMap(d=>d.data);
  const maxV=Math.max(...all,1), minV=Math.min(...all,0), range=maxV-minV||1;

  ctx.fillStyle='#fff'; ctx.fillRect(0,0,W,H);

  for(let i=0;i<=4;i++){
    const y=PAD.top+(cH/4)*i;
    ctx.beginPath(); ctx.setLineDash([4,4]); ctx.strokeStyle='rgba(61,90,62,.08)'; ctx.lineWidth=1;
    ctx.moveTo(PAD.left,y); ctx.lineTo(PAD.left+cW,y); ctx.stroke(); ctx.setLineDash([]);
    const v=maxV-(range/4)*i;
    ctx.fillStyle='#9AAA9B'; ctx.font='10px sans-serif'; ctx.textAlign='right';
    ctx.fillText(fmtShort(v),PAD.left-5,y+4);
  }
  const step=labels.length>1?cW/(labels.length-1):cW;
  ctx.fillStyle='#9AAA9B'; ctx.textAlign='center'; ctx.font='10px sans-serif';
  labels.forEach((l,i)=>ctx.fillText(l,PAD.left+(labels.length>1?i*step:cW/2),H-PAD.bottom+16));

  datasets.forEach(ds=>{
    const pts=ds.data.map((v,i)=>({
      x:PAD.left+(labels.length>1?i*step:cW/2),
      y:PAD.top+cH-((v-minV)/range)*cH,
    }));
    if(!ds.dashed){
      ctx.beginPath(); ctx.moveTo(pts[0].x,PAD.top+cH);
      pts.forEach(p=>ctx.lineTo(p.x,p.y));
      ctx.lineTo(pts[pts.length-1].x,PAD.top+cH); ctx.closePath();
      const g=ctx.createLinearGradient(0,PAD.top,0,PAD.top+cH);
      g.addColorStop(0,ds.color+'44'); g.addColorStop(1,ds.color+'05');
      ctx.fillStyle=g; ctx.fill();
    }
    ctx.beginPath(); ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length;i++){const cx=(pts[i-1].x+pts[i].x)/2;ctx.bezierCurveTo(cx,pts[i-1].y,cx,pts[i].y,pts[i].x,pts[i].y);}
    ctx.strokeStyle=ds.color; ctx.lineWidth=ds.dashed?1.5:2.5; ctx.lineJoin='round';
    ctx.setLineDash(ds.dashed?[6,4]:[]); ctx.stroke(); ctx.setLineDash([]);
    if(!ds.dashed)pts.forEach(p=>{
      ctx.beginPath(); ctx.arc(p.x,p.y,4,0,Math.PI*2);
      ctx.fillStyle='#fff'; ctx.fill(); ctx.strokeStyle=ds.color; ctx.lineWidth=2; ctx.stroke();
    });
  });
}

function drawBars(id,data,labels,H=160){
  const s=setupCanvas(id,H); if(!s)return;
  const {ctx,W}=s;
  const PAD={top:16,right:16,bottom:32,left:52};
  const cW=W-PAD.left-PAD.right, cH=H-PAD.top-PAD.bottom;
  const maxAbs=Math.max(...data.map(Math.abs),1);

  ctx.fillStyle='#fff'; ctx.fillRect(0,0,W,H);
  const zY=PAD.top+cH/2;
  ctx.beginPath(); ctx.setLineDash([4,4]); ctx.strokeStyle='rgba(61,90,62,.15)'; ctx.lineWidth=1;
  ctx.moveTo(PAD.left,zY); ctx.lineTo(PAD.left+cW,zY); ctx.stroke(); ctx.setLineDash([]);
  ctx.fillStyle='#9AAA9B'; ctx.font='10px sans-serif'; ctx.textAlign='right';
  ctx.fillText(fmtShort(maxAbs),PAD.left-5,PAD.top+8);
  ctx.fillText('0',PAD.left-5,zY+4);
  ctx.fillText(fmtShort(-maxAbs),PAD.left-5,PAD.top+cH+4);

  const bW=Math.max(cW/data.length*0.55,4);
  const sX=data.length>1?cW/(data.length-1):cW;
  data.forEach((v,i)=>{
    const x=PAD.left+(data.length>1?i*sX:cW/2);
    const bH=Math.abs(v)/maxAbs*(cH/2);
    const y=v>=0?zY-bH:zY;
    ctx.fillStyle=v>=0?'#3B543688':'#B03A2A88';
    ctx.beginPath(); ctx.roundRect(x-bW/2,y,bW,Math.max(bH,2),3); ctx.fill();
    ctx.fillStyle='#9AAA9B'; ctx.textAlign='center'; ctx.font='10px sans-serif';
    ctx.fillText(labels[i],x,H-PAD.bottom+16);
  });
}

