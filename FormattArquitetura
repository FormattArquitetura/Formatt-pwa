function editFinItem(id, tipo) {
  const arr  = tipo === 'receber' ? getReceber() : getPagar();
  const item = arr.find(i => i.id === id);
  if (!item) return;
  editingFinId   = id;
  editingFinType = tipo;
  document.getElementById('fi-desc').value       = item.desc;
  document.getElementById('fi-valor').value      = item.valor;
  document.getElementById('fi-data').value       = item.data || '';
  document.getElementById('fi-obs').value        = item.obs || '';
  document.getElementById('fi-tipo').value       = item.tipo;
  onFinTipoChange(document.getElementById('fi-tipo'));
  document.getElementById('fi-categoria').value  = item.categoria || '';
  document.getElementById('fi-status').value     = item.status;
  if (item.recorrencia) document.getElementById('fi-recorrencia').value = item.recorrencia;
  document.getElementById('fin-delete-btn').style.display = 'block';
  document.getElementById('fin-modal-title').textContent  = item.desc;
  document.getElementById('fin-modal').classList.add('open');
}

function saveFinItem() {
  const desc  = document.getElementById('fi-desc').value.trim();
  if (!desc) { alert('Informe a descrição'); return; }
  const item = {
    desc,
    valor:       parseFloat(document.getElementById('fi-valor').value) || 0,
    data:        document.getElementById('fi-data').value,
    tipo:        document.getElementById('fi-tipo').value,
    categoria:   document.getElementById('fi-categoria').value,
    status:      document.getElementById('fi-status').value,
    recorrencia: document.getElementById('fi-recorrencia').value || '',
    obs:         document.getElementById('fi-obs').value,
  };
  const isRec = item.tipo === 'receber-manual';
  if (isRec) {
    const arr = getReceber();
    if (editingFinId !== null) {
      const idx = arr.findIndex(i => i.id === editingFinId);
      if (idx !== -1) arr[idx] = { ...arr[idx], ...item };
    } else {
      arr.push({ id: Date.now(), ...item });
    }
    saveReceber(arr);
  } else {
    const arr = getPagar();
    if (editingFinId !== null) {
      const idx = arr.findIndex(i => i.id === editingFinId);
      if (idx !== -1) arr[idx] = { ...arr[idx], ...item };
    } else {
      arr.push({ id: Date.now(), ...item });
    }
    savePagar(arr);
  }
  closefinModal();
  renderAll();
}

function deleteFinItem() {
  if (!editingFinId || !confirm('Deletar este lançamento?')) return;
  if (editingFinType === 'receber') {
    saveReceber(getReceber().filter(i => i.id !== editingFinId));
  } else {
    savePagar(getPagar().filter(i => i.id !== editingFinId));
  }
  closefinModal();
  renderAll();
}

function labelStatus(s) {
  return { pendente:'Pendente', recebido:'Recebido', pago:'Pago', vencido:'Vencido' }[s] || s;
}

/* ════════════════════════════════════
   GRÁFICOS DE LINHA — Canvas puro
════════════════════════════════════ */

function drawLineChart(canvasId, datasets, labels, opts = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const dpr = window.devicePixelRatio || 1;
  const W   = canvas.offsetWidth  || canvas.parentElement.offsetWidth || 320;
  const H   = parseInt(canvas.getAttribute('height')) || 180;
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);

  const PAD = { top: 16, right: 16, bottom: 36, left: 60 };
  const chartW = W - PAD.left - PAD.right;
  const chartH = H - PAD.top  - PAD.bottom;

  // Calcular min/max
  const allVals = datasets.flatMap(d => d.data);
  const maxVal  = Math.max(...allVals, 1);
  const minVal  = 0;
  const range   = maxVal - minVal || 1;

  // Fundo
  ctx.fillStyle = '#fff';
  ctx.fillRect(0, 0, W, H);

  // Grid horizontal
  const gridLines = 4;
  ctx.setLineDash([4, 4]);
  ctx.strokeStyle = 'rgba(61,90,62,0.08)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= gridLines; i++) {
    const y = PAD.top + (chartH / gridLines) * i;
    ctx.beginPath(); ctx.moveTo(PAD.left, y); ctx.lineTo(PAD.left + chartW, y);
    ctx.stroke();
    // Label eixo Y
    const val = maxVal - (range / gridLines) * i;
    ctx.setLineDash([]);
    ctx.fillStyle = '#9AAA9B';
    ctx.font = `${10 * dpr / dpr}px sans-serif`;
    ctx.textAlign = 'right';
    ctx.fillText(fmtValShort(val), PAD.left - 6, y + 4);
    ctx.setLineDash([4, 4]);
  }
  ctx.setLineDash([]);

  // Eixo X — labels
  ctx.fillStyle = '#9AAA9B';
  ctx.textAlign = 'center';
  ctx.font = '10px sans-serif';
  const step = labels.length > 1 ? chartW / (labels.length - 1) : chartW;
  labels.forEach((lbl, i) => {
    const x = PAD.left + (labels.length > 1 ? i * step : chartW / 2);
    ctx.fillText(lbl, x, H - PAD.bottom + 18);
  });

  // Linha de cada dataset
  datasets.forEach(ds => {
    if (!ds.data.length) return;
    const pts = ds.data.map((v, i) => ({
      x: PAD.left + (labels.length > 1 ? i * step : chartW / 2),
      y: PAD.top + chartH - ((v - minVal) / range) * chartH,
    }));

    // Área preenchida
    ctx.beginPath();
    ctx.moveTo(pts[0].x, PAD.top + chartH);
    pts.forEach(p => ctx.lineTo(p.x, p.y));
    ctx.lineTo(pts[pts.length - 1].x, PAD.top + chartH);
    ctx.closePath();
    const grad = ctx.createLinearGradient(0, PAD.top, 0, PAD.top + chartH);
    grad.addColorStop(0, ds.color + '33');
    grad.addColorStop(1, ds.color + '05');
    ctx.fillStyle = grad;
    ctx.fill();

    // Linha
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pts[0].y);
    if (pts.length === 1) {
      ctx.arc(pts[0].x, pts[0].y, 3, 0, Math.PI * 2);
    } else {
      for (let i = 1; i < pts.length; i++) {
        // Curva suave
        const cp1x = (pts[i-1].x + pts[i].x) / 2;
        ctx.bezierCurveTo(cp1x, pts[i-1].y, cp1x, pts[i].y, pts[i].x, pts[i].y);
      }
    }
    ctx.strokeStyle = ds.color;
    ctx.lineWidth = 2.5;
    ctx.lineJoin = 'round';
    ctx.stroke();

    // Pontos
    pts.forEach(p => {
      ctx.beginPath();
      ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
      ctx.fillStyle = '#fff';
      ctx.fill();
      ctx.strokeStyle = ds.color;
      ctx.lineWidth = 2;
      ctx.stroke();
    });
  });
}

function fmtValShort(v) {
  if (v >= 1000) return 'R$' + (v/1000).toFixed(0) + 'k';
  return 'R$' + v.toFixed(0);
}

// Agrupa lançamentos por mês (últimos N meses)
function agruparPorMes(items, campo, n = 6) {
  const meses = [];
  const now = new Date();
  for (let i = n - 1; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    meses.push({
      key:   d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0'),
      label: d.toLocaleDateString('pt-BR', {month:'short', year:'2-digit'}),
      total: 0,
    });
  }
  items.forEach(item => {
    if (!item[campo]) return;
    const key = item[campo].substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.total += (item.valor || 0);
  });
  return meses;
}

/* ── Gráfico Espectro: Entradas vs Saídas por mês ── */
function renderChartEspectro() {
  const receber = getReceber();
  const pagar   = getPagar();
  const n = 6;

  const mRec = agruparPorMes(receber, 'data', n);
  const mPag = agruparPorMes(pagar,   'data', n);
  const labels = mRec.map(m => m.label);

  drawLineChart('chart-espectro', [
    { label: 'A receber', data: mRec.map(m => m.total), color: '#4A7FA5' },
    { label: 'A pagar',   data: mPag.map(m => m.total), color: '#B05A3A' },
  ], labels);

  document.getElementById('chart-espectro-legend').innerHTML = `
    <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#4A7FA5;"></div>A receber</div>
    <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#B05A3A;"></div>A pagar</div>`;
}

/* ── Gráfico Caixa: Histórico de saldo ── */
function renderChartCaixa() {
  // Gráfico de projeção
  const pd = window._projecaoData;
  if (pd) {
    let saldo = pd.saldoAtual;
    const labels = [];
    const saldos = [];
    const entradas = [];
    const saidas = [];
    pd.meses.forEach((m, i) => {
      if (i > 0) saldo += (m.entradas - m.saidas);
      labels.push(m.label);
      saldos.push(saldo);
      entradas.push(m.entradas);
      saidas.push(m.saidas);
    });
    drawLineChart('chart-projecao', [
      { label: 'Saldo projetado', data: saldos,   color: '#3B5436' },
      { label: 'Entradas',        data: entradas,  color: '#4A7FA5' },
      { label: 'Saídas',          data: saidas,    color: '#B05A3A' },
    ], labels);
    document.getElementById('chart-projecao-legend').innerHTML = `
      <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#3B5436;"></div>Saldo projetado</div>
      <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#4A7FA5;"></div>Entradas</div>
      <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#B05A3A;"></div>Saídas</div>`;
  }

  // Gráfico de histórico de saldo
  const hist = JSON.parse(localStorage.getItem('fa-fin-saldo-hist') || '[]');
  if (hist.length < 2) {
    const canvas = document.getElementById('chart-caixa');
    if (!canvas) return;
    const W = canvas.offsetWidth || 320, H = 160;
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#fff'; ctx.fillRect(0,0,W,H);
    ctx.fillStyle = '#9AAA9B'; ctx.font = '12px sans-serif'; ctx.textAlign = 'center';
    ctx.fillText('Atualize o saldo algumas vezes para ver a evolução', W/2, H/2);
    return;
  }
  drawLineChart('chart-caixa', [
    { label: 'Saldo', data: hist.map(h => h.valor), color: '#3B5436' },
  ], hist.map(h => fmtDateShort(h.data)));
}

/* ── Gráfico A Receber: entradas por vencimento ── */
function renderChartReceber() {
  const meses = agruparPorMes(getReceber(), 'data', 6);
  drawLineChart('chart-receber', [
