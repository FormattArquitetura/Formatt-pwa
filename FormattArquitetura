  if (!el) return;

  const captacao      = projects.filter(p => p.status === 'captacao');
  const andamento     = projects.filter(p => p.status === 'andamento');
  const finalizados   = projects.filter(p => p.status === 'finalizados');
  const naoContratado = projects.filter(p => p.status === 'nao-contratado');
  const total = projects.length;

  const fmtVal  = v => v ? 'R$\u00a0' + Number(v).toLocaleString('pt-BR') : '—';
  const fmtDate = d => d ? new Date(d + 'T12:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short'}) : '';
  const sumVal  = (arr, field) => arr.reduce((s, p) => s + (Number(p[field]) || 0), 0);

  const recConfirmada = sumVal(andamento, 'valor');
  const recPotencial  = sumVal(captacao, 'valorCap');
  const progMedio = andamento.length
    ? Math.round(andamento.reduce((s, p) => s + (Number(p.perc) || 0), 0) / andamento.length)
    : 0;

  // Bloco colapsável por status
  function statusBlock(id, dotColor, title, count, singular, rows) {
    if (!rows.length) return '';
    const rowsHtml = rows.map(r => `
      <div class="status-block-row" onclick="editProject(${r.id})">
        <div>
          <div class="sbr-name">${r.cliente}</div>
          <div class="sbr-type">${Array.isArray(r.tipo) ? r.tipo.join(' · ') : (r.tipo || '—')}</div>
        </div>
        <div class="sbr-right">
          <div class="sbr-val">${r._val}</div>
          ${r._date ? `<div class="sbr-date">${r._date}</div>` : ''}
        </div>
      </div>`).join('');

    return `
      <div class="status-block">
        <div class="status-block-header" onclick="toggleBlock('${id}')">
          <div class="status-block-title">
            <div class="status-block-dot" style="background:${dotColor};"></div>
            ${title}
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="status-block-count">${count} ${count === 1 ? singular : (singular === 'projeto' ? 'projetos' : 'leads')}</span>
            <span class="status-block-arrow" id="arrow-${id}">▼</span>
          </div>
        </div>
        <div class="status-block-list open" id="list-block-${id}">${rowsHtml}</div>
      </div>`;
  }

  const rowsCap = captacao.map(p => ({
    ...p, _val: fmtVal(p.valorCap),
    _date: p.prazo ? '⏳ ' + fmtDate(p.prazo) : '',
  }));
  const rowsAnd = andamento.map(p => ({
    ...p, _val: fmtVal(p.valor),
    _date: p.entrega ? '📅 ' + fmtDate(p.entrega) : (p.perc ? p.perc + '%' : ''),
  }));
  const rowsFin = finalizados.map(p => ({
    ...p, _val: fmtVal(p.valor),
    _date: p.entrega ? fmtDate(p.entrega) : '',
  }));
  const rowsNao = naoContratado.map(p => ({
    ...p, _val: fmtVal(p.valorCap || p.valor),
    _date: p.prazo ? fmtDate(p.prazo) : '',
  }));

  el.innerHTML = `
    <!-- MÉTRICAS -->
    <div class="todos-metrics">
      <div class="metric-card">
        <div class="metric-card-label">Total</div>
        <div class="metric-card-val">${total}</div>
        <div class="metric-card-sub">projetos</div>
      </div>
      <div class="metric-card">
        <div class="metric-card-label">Receita prevista</div>
        <div class="metric-card-val" style="font-size:15px;">${recConfirmada ? 'R$\u00a0' + Number(recConfirmada).toLocaleString('pt-BR') : '—'}</div>
        <div class="metric-card-sub">em andamento</div>
      </div>
      <div class="metric-card">
        <div class="metric-card-label">Potencial</div>
        <div class="metric-card-val" style="font-size:15px;color:#C48A00;">${recPotencial ? 'R$\u00a0' + Number(recPotencial).toLocaleString('pt-BR') : '—'}</div>
        <div class="metric-card-sub">em captação</div>
      </div>
    </div>

    <!-- BLOCOS POR STATUS: Captação → Andamento → Finalizados → Não contratados -->
    ${statusBlock('cap', '#C48A00',      'Em captação',      captacao.length,      'lead',    rowsCap)}
    ${statusBlock('and', '#6BA3C8',      'Em andamento',     andamento.length,     'projeto', rowsAnd)}
    ${statusBlock('fin', 'var(--verde)', 'Finalizados',      finalizados.length,   'projeto', rowsFin)}
    ${statusBlock('nao', '#B0A0A0',      'Não contratados',  naoContratado.length, 'lead',    rowsNao)}

    ${!total ? `<div class="proj-empty"><div class="proj-empty-title">Nenhum projeto ainda</div><div class="proj-empty-sub">Clique em + Novo para começar</div></div>` : ''}
  `;
}

function toggleBlock(id) {
  const list  = document.getElementById('list-block-' + id);
  const arrow = document.getElementById('arrow-' + id);
  if (!list) return;
  list.classList.toggle('open');
  if (arrow) arrow.classList.toggle('open');
}

const ORIGEM_LABEL = {
  indicacao: 'Indicação', instagram: 'Instagram',
  site: 'Site / Google', whatsapp: 'WhatsApp', outro: 'Outro'
};

function renderProjList(status, list) {
  const listEl  = document.getElementById('list-'  + status);
  const emptyEl = document.getElementById('empty-' + status);
  if (!listEl || !emptyEl) return;

  if (!list.length) {
    listEl.innerHTML = '';
    emptyEl.style.display = 'block';
    return;
  }
  emptyEl.style.display = 'none';

  const fmtVal  = v => v ? 'R$ ' + Number(v).toLocaleString('pt-BR') : '—';
  const fmtDate = d => d ? new Date(d + 'T12:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short', year:'2-digit'}) : '';

  if (status === 'captacao' || status === 'nao-contratado') {
    const isNao = status === 'nao-contratado';
    listEl.innerHTML = list.map(p => `
      <div class="proj-card ${isNao ? 'nao-contratado' : 'captacao'}" onclick="editProject(${p.id})">
        <div class="proj-card-header">
          <div>
            <div class="proj-card-client">${p.cliente}</div>
            <div class="proj-card-type">${Array.isArray(p.tipo) ? p.tipo.join(' · ') : (p.tipo || '—')}</div>
          </div>
          <span class="proj-card-badge ${isNao ? 'badge-nao-contratado' : 'badge-captacao'}">
            ${isNao ? 'Não contratado' : 'Em captação'}
          </span>
        </div>
        <div class="proj-card-meta">
          <span class="proj-card-val">${fmtVal(p.valorCap)}</span>
          ${!isNao && p.prazo ? `<span class="captacao-prazo">⏳ Resp. até ${fmtDate(p.prazo)}</span>` : ''}
        </div>
        ${!isNao && p.origem ? `<div class="captacao-tag">📌 ${ORIGEM_LABEL[p.origem] || p.origem}</div>` : ''}
        ${isNao && p.obs ? `<div class="captacao-prazo" style="margin-top:6px;">${p.obs}</div>` : ''}
      </div>
    `).join('');
    return;
  }

  listEl.innerHTML = list.map(p => `
    <div class="proj-card" onclick="editProject(${p.id})">
      <div class="proj-card-header">
        <div>
          <div class="proj-card-client">${p.cliente}</div>
          <div class="proj-card-type">${Array.isArray(p.tipo) ? p.tipo.join(' · ') : (p.tipo || '—')}</div>
        </div>
        <span class="proj-card-badge ${status === 'andamento' ? 'badge-andamento' : 'badge-finalizado'}">
          ${status === 'andamento' ? 'Em andamento' : 'Finalizado'}
        </span>
      </div>
      <div class="proj-card-meta">
        <span class="proj-card-val">${fmtVal(p.valor)}</span>
        ${p.entrega ? `<span class="proj-card-date">📅 ${fmtDate(p.entrega)}</span>` : ''}
      </div>
      ${p.perc > 0 ? `
      <div class="proj-progress">
        <div class="proj-progress-label"><span>Progresso</span><span>${p.perc}%</span></div>
        <div class="proj-progress-bar"><div class="proj-progress-fill" style="width:${p.perc}%"></div></div>
      </div>` : ''}
    </div>
  `).join('');
}

/* ── TABS ── */
function switchTab(tab, btn) {
  document.querySelectorAll('.proj-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.proj-section').forEach(s => s.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-' + tab).classList.add('active');
}

/* ── TOGGLE CAMPOS NO MODAL ── */
function onStatusChange(sel) {
  const isCap = sel.value === 'captacao' || sel.value === 'nao-contratado';
  document.getElementById('fields-projeto').style.display  = isCap ? 'none' : 'block';
  document.getElementById('fields-captacao').style.display = isCap ? 'block' : 'none';
}

/* ── MODAL NOVO ── */
function openNewProject() {
  editingId = null;
  document.getElementById('pf-cliente').value   = '';
  clearTipos();
  setTipos(['Projeto Arquitetônico']);
  document.getElementById('pf-status').value     = 'andamento';
  document.getElementById('pf-valor').value      = '';
  document.getElementById('pf-perc').value       = '0';
  document.getElementById('pf-inicio').value     = new Date().toISOString().split('T')[0];
  document.getElementById('pf-entrega').value    = '';
  document.getElementById('pf-valor-cap').value  = '';
  document.getElementById('pf-prazo').value      = '';
  document.getElementById('pf-origem').value     = '';
  document.getElementById('pf-obs').value        = '';
  document.getElementById('fields-projeto').style.display  = 'block';
  document.getElementById('fields-captacao').style.display = 'none';
  document.getElementById('proj-modal-title').textContent  = 'Novo Projeto';
  document.getElementById('proj-delete-btn').style.display = 'none';
  document.getElementById('proj-save-btn').textContent     = '✓ Salvar';
  document.getElementById('proj-modal').classList.add('open');
}

function closeNewProject(e) {
  if (e.target === document.getElementById('proj-modal')) {
    document.getElementById('proj-modal').classList.remove('open');
  }
}

/* ── MODAL EDITAR ── */
function editProject(id) {
  const p = loadProjects().find(x => x.id === id);
  if (!p) return;
  editingId = id;

  const isCap = p.status === 'captacao' || p.status === 'nao-contratado';
  const isAnd = p.status === 'andamento';

  document.getElementById('pf-cliente').value   = p.cliente;
  clearTipos();
  setTipos(Array.isArray(p.tipo) ? p.tipo : (p.tipo ? [p.tipo] : []));
  document.getElementById('pf-status').value     = p.status;
  document.getElementById('pf-obs').value        = p.obs || '';
  document.getElementById('fields-projeto').style.display   = isCap ? 'none' : 'block';
  document.getElementById('fields-captacao').style.display  = isCap ? 'block' : 'none';
  document.getElementById('fields-checklist').style.display = isAnd ? 'block' : 'none';

  if (isCap) {
    document.getElementById('pf-valor-cap').value = p.valorCap || '';
    document.getElementById('pf-prazo').value     = p.prazo    || '';
    document.getElementById('pf-origem').value    = p.origem   || '';
  } else {
    document.getElementById('pf-valor').value   = p.valor   || '';
    document.getElementById('pf-perc').value    = p.perc    || 0;
    document.getElementById('pf-inicio').value  = p.inicio  || '';
    document.getElementById('pf-entrega').value = p.entrega || '';
  }

  // Monta checklist se em andamento
  if (isAnd) renderChecklist(p);

  document.getElementById('proj-modal-title').textContent  = p.cliente;
  document.getElementById('proj-delete-btn').style.display = 'block';
  document.getElementById('proj-save-btn').textContent     = '✓ Salvar alterações';
  document.getElementById('proj-modal').classList.add('open');
}

/* ── CHECKLIST ── */
function renderChecklist(p) {
  const tipos  = Array.isArray(p.tipo) ? p.tipo : (p.tipo ? [p.tipo] : []);
  const feitos = Array.isArray(p.tipoFeito) ? p.tipoFeito : [];
  const wrap   = document.getElementById('pf-checklist');

  if (!tipos.length) {
    wrap.innerHTML = '<div style="font-size:12px;color:var(--muted);">Nenhum serviço selecionado.</div>';
    return;
  }

  const pct = Math.round(feitos.length / tipos.length * 100);

  wrap.innerHTML = tipos.map(t => `
    <div class="check-item ${feitos.includes(t) ? 'done' : ''}"
         data-tipo="${encodeURIComponent(t)}"
         onclick="toggleCheck(this)">
      <div class="check-box"></div>
      <span class="check-label">${t}</span>
    </div>
  `).join('') + `<div class="check-perc" id="check-perc-label">${feitos.length} de ${tipos.length} concluído${feitos.length !== 1 ? 's' : ''} — ${pct}%</div>`;
}

function toggleCheck(el) {
  const tipo     = decodeURIComponent(el.dataset.tipo);
  const projects = loadProjects();
  const idx      = projects.findIndex(p => p.id === editingId);
  if (idx === -1) return;

  const p      = projects[idx];
  const tipos  = Array.isArray(p.tipo) ? p.tipo : [];
  let feitos   = Array.isArray(p.tipoFeito) ? [...p.tipoFeito] : [];

  if (feitos.includes(tipo)) {
    feitos = feitos.filter(t => t !== tipo);
    el.classList.remove('done');
  } else {
    feitos.push(tipo);
    el.classList.add('done');
  }

  // Recalcula % e salva imediatamente
  const pct = tipos.length > 0 ? Math.round(feitos.length / tipos.length * 100) : 0;
  projects[idx].tipoFeito = feitos;
  projects[idx].perc      = pct;
  saveProjects(projects);

  // Atualiza o contador
  const label = document.getElementById('check-perc-label');
  if (label) label.textContent = `${feitos.length} de ${tipos.length} concluído${feitos.length !== 1 ? 's' : ''} — ${pct}%`;

  // Atualiza o campo % no formulário
  const percEl = document.getElementById('pf-perc');
  if (percEl) percEl.value = pct;

  renderProjects();
}

/* ── SALVAR ── */
function saveProject() {
  const cliente = document.getElementById('pf-cliente').value.trim();
  if (!cliente) { alert('Informe o nome do cliente'); return; }

  const status = document.getElementById('pf-status').value;
  const isCap  = status === 'captacao' || status === 'nao-contratado';

  const base = {
    cliente,
    tipo:   getTipos(),
    status,
    obs:    document.getElementById('pf-obs').value,
  };

  const extra = isCap ? {
    valorCap: Number(document.getElementById('pf-valor-cap').value) || 0,
    prazo:    document.getElementById('pf-prazo').value,
    origem:   document.getElementById('pf-origem').value,
    // limpar campos de projeto
    valor: 0, perc: 0, inicio: '', entrega: '',
  } : {
    valor:   Number(document.getElementById('pf-valor').value) || 0,
    perc:    Number(document.getElementById('pf-perc').value)  || 0,
    inicio:  document.getElementById('pf-inicio').value,
    entrega: document.getElementById('pf-entrega').value,
    // limpar campos de captação
    valorCap: 0, prazo: '', origem: '',
  };

  const projects = loadProjects();
  if (editingId !== null) {
    const idx = projects.findIndex(p => p.id === editingId);
    if (idx !== -1) projects[idx] = { ...projects[idx], ...base, ...extra };
  } else {
    projects.push({ id: Date.now(), ...base, ...extra, tipoFeito: [] });
  }

  saveProjects(projects);
  document.getElementById('proj-modal').classList.remove('open');
  renderProjects();

  // Ir para a aba correta (não-contratado vai para Todos)
  const destino = status === 'nao-contratado' ? 'todos' : status;
  const btn = document.querySelector(`.proj-tab[onclick*="'${destino}'"]`);
  if (btn) switchTab(destino, btn);
}

/* ── DELETAR ── */
function deleteProject() {
  if (!editingId || !confirm('Deletar este registro?')) return;
  saveProjects(loadProjects().filter(p => p.id !== editingId));
  document.getElementById('proj-modal').classList.remove('open');
  renderProjects();
}

/* ── CHIPS DE TIPO DE SERVIÇO ── */
const TIPOS_FIXOS = [
  'Projeto Arquitetônico','Planta Baixa','Projeto Executivo',
  'Interiores','Ilustração 3D','Fachada','Paisagismo','Projeto Legal'
];

function getTipos() {
  // Retorna array de strings com os tipos selecionados
  return Array.from(document.querySelectorAll('.tipo-chip.selected'))
    .map(c => c.dataset.tipo)
    .filter(t => t && t !== '__outros__');
}

function clearTipos() {
  // Desmarca todos os chips e remove chips customizados
  document.querySelectorAll('.tipo-chip').forEach(c => c.classList.remove('selected'));
  document.querySelectorAll('.tipo-chip-custom').forEach(c => c.remove());
  document.getElementById('tipo-outro-wrap').style.display = 'none';
  document.getElementById('tipo-outro-input').value = '';
}

function setTipos(tipos) {
  if (!tipos || !tipos.length) return;
  tipos.forEach(tipo => {
    // Procura chip fixo
    const chip = document.querySelector(`.tipo-chip[data-tipo="${CSS.escape(tipo)}"]`);
    if (chip && tipo !== '__outros__') {
      chip.classList.add('selected');
    } else if (!TIPOS_FIXOS.includes(tipo) && tipo !== '__outros__') {
      // É um tipo customizado — cria o chip
      _addCustomChip(tipo, true);
    }
  });
}

function toggleTipo(btn) {
  btn.classList.toggle('selected');
}

function toggleOutros(btn) {
  const wrap = document.getElementById('tipo-outro-wrap');
  const visible = wrap.style.display === 'flex';
  wrap.style.display = visible ? 'none' : 'flex';
  btn.classList.toggle('selected', !visible);
  if (!visible) setTimeout(() => document.getElementById('tipo-outro-input').focus(), 50);
}

function addOutroTipo() {
  const input = document.getElementById('tipo-outro-input');
  const nome = input.value.trim();
  if (!nome) { input.focus(); return; }
  // Verifica duplicata
  const existe = document.querySelector(`.tipo-chip[data-tipo="${CSS.escape(nome)}"]`);
  if (existe) {
    existe.classList.add('selected');
  } else {
    _addCustomChip(nome, true);
  }
  input.value = '';
  // Fecha o campo mas mantém o botão Outros ativo enquanto há input aberto
}

function _addCustomChip(nome, selected) {
  const btn = document.querySelector('.tipo-chip-outros');
  const chip = document.createElement('button');
  chip.type = 'button';
  chip.className = 'tipo-chip tipo-chip-custom' + (selected ? ' selected' : '');
  chip.dataset.tipo = nome;
  chip.innerHTML = nome + '<span class="chip-remove" onclick="removeCustomChip(event,this)">✕</span>';
  chip.onclick = function(e) {
    if (!e.target.classList.contains('chip-remove')) toggleTipo(chip);
  };
  // Insere antes do botão Outros
  btn.parentNode.insertBefore(chip, btn);
}

function removeCustomChip(e, span) {
  e.stopPropagation();
  span.closest('.tipo-chip-custom').remove();
}

/* ── START ── */
renderProjects();


window.switchTab        = switchTab;
window.openNewProject   = openNewProject;
window.editProject      = editProject;
window.saveProject      = saveProject;
window.deleteProject    = deleteProject;
window.onStatusChange   = onStatusChange;
window.toggleTipo       = toggleTipo;
window.addOutroTipo     = addOutroTipo;
window.removeCustomChip = removeCustomChip;
window.toggleCheck      = toggleCheck;
})();
</script>


