<script>
// === MÓDULO AGENDA ===
(function() {

/* ═══════════════════════════════════════════
   CALENDÁRIO — módulo standalone
   Dados em localStorage: fa-agenda-v1
═══════════════════════════════════════════ */

const CAL_KEY = 'fa-agenda-v1';
const CUSTOM_TIPOS_KEY = 'fa-custom-tipos';

const TIPO_LABELS = {
  'reuniao-online': 'Reunião online',
  'reuniao-presencial': 'Reunião presencial',
  'visita-tecnica': 'Visita técnica',
  'dedicacao-formatt': 'Dedicação Formatt'
};
const MONTHS = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const DAYS_SHORT = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

let calView = 'month';
let calDate = new Date();
let calSelected = new Date();
let calFilterType = null;
let editingEventId = null;
let selectedCustomColor = '#A8C8F0';
let selectedCustomBorder = '#7AAEE0';

/* ── STORAGE ── */
function loadEvents() { return JSON.parse(localStorage.getItem(CAL_KEY) || '[]'); }
function saveEvents(e) { localStorage.setItem(CAL_KEY, JSON.stringify(e)); }
function loadCustomTipos() { return JSON.parse(localStorage.getItem(CUSTOM_TIPOS_KEY) || '[]'); }
function saveCustomTipos(tipos) { localStorage.setItem(CUSTOM_TIPOS_KEY, JSON.stringify(tipos)); }

/* ── INIT ── */
function initCalendar() {
  calDate = new Date();
  calSelected = new Date();
  initCustomTipos();
  renderCalendar();
}

/* ── FILTER ── */
function filterByType(tipo) {
  calFilterType = tipo;
  document.querySelectorAll('.agenda-legend-item').forEach(el => el.classList.remove('agenda-legend-active'));
  const active = tipo ? document.getElementById('leg-' + tipo) : document.getElementById('leg-all');
  if (active) active.classList.add('agenda-legend-active');
  renderCalendar();
}

/* ── NAVIGATION ── */
function setCalView(view, btn) {
  calView = view;
  if (view !== 'month') closeDayPanel();
  document.querySelectorAll('.cal-view-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderCalendar();
}

function calNav(dir) {
  if (calView === 'month') {
    calDate.setMonth(calDate.getMonth() + dir);
  } else if (calView === 'week') {
    calDate.setDate(calDate.getDate() + dir * 7);
  } else {
    calDate.setDate(calDate.getDate() + dir);
    calSelected = new Date(calDate);
  }
  renderCalendar();
}

/* ── RENDER ── */
function renderCalendar() {
  const wd = document.getElementById('cal-weekdays');
  const grid = document.getElementById('cal-grid');
  const monthYear = document.getElementById('cal-month-year');

  if (calView === 'month') {
    monthYear.textContent = MONTHS[calDate.getMonth()] + ' ' + calDate.getFullYear();
    wd.classList.remove('hidden');
    grid.className = 'cal-grid';
    renderMonthGrid();
  } else if (calView === 'week') {
    const startOfWeek = new Date(calDate);
    startOfWeek.setDate(calDate.getDate() - calDate.getDay());
    const endOfWeek = new Date(startOfWeek);
    endOfWeek.setDate(startOfWeek.getDate() + 6);
    const sameMonth = startOfWeek.getMonth() === endOfWeek.getMonth();
    monthYear.textContent = sameMonth
      ? MONTHS[startOfWeek.getMonth()] + ' ' + startOfWeek.getFullYear()
      : MONTHS[startOfWeek.getMonth()].substring(0,3) + ' – ' + MONTHS[endOfWeek.getMonth()].substring(0,3) + ' ' + endOfWeek.getFullYear();
    wd.classList.add('hidden');
    grid.className = 'cal-grid tl-mode';
    renderWeekGrid(startOfWeek);
  } else {
    monthYear.textContent = DAYS_SHORT[calSelected.getDay()] + ', ' + calSelected.getDate() + ' de ' + MONTHS[calSelected.getMonth()] + ' ' + calSelected.getFullYear();
    wd.classList.add('hidden');
    grid.className = 'cal-grid tl-mode';
    renderDayView();
  }
}

function renderMonthGrid() {
  const grid = document.getElementById('cal-grid');
  const year = calDate.getFullYear(), month = calDate.getMonth();
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const prevDays = new Date(year, month, 0).getDate();
  const today = new Date();
  const events = loadEvents();

  let cells = '';
  for (let i = firstDay - 1; i >= 0; i--) {
    cells += `<div class="cal-day other-month"><span class="cal-day-num">${prevDays - i}</span></div>`;
  }
  for (let d = 1; d <= daysInMonth; d++) {
    const isToday = d === today.getDate() && month === today.getMonth() && year === today.getFullYear();
    const isSel = d === calSelected.getDate() && month === calSelected.getMonth() && year === calSelected.getFullYear();
    const dateStr = year + '-' + String(month+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
    const dayEvents = events.filter(e => e.data === dateStr && (!calFilterType || e.tipo === calFilterType));
    const TIPO_COLORS = {'reuniao-online':'#7AAEE0','reuniao-presencial':'#F0A060','visita-tecnica':'#F0CC50','dedicacao-formatt':'#78B888'};
    const dots = dayEvents.map(e => {
      const ct = loadCustomTipos().find(t => t.id === e.tipo);
      const color = TIPO_COLORS[e.tipo] || (ct ? ct.border : '#999');
      return `<span class="cal-day-dot-item" style="background:${color};"></span>`;
    }).join('');
    cells += `<div class="cal-day${isToday?' today':''}${isSel?' selected':''}" onclick="selectDay(${year},${month},${d})">
      <span class="cal-day-num">${d}</span>
      ${dots ? `<div class="cal-day-dots">${dots}</div>` : ''}
    </div>`;
  }
  const total = firstDay + daysInMonth;
  const remaining = total % 7 === 0 ? 0 : 7 - (total % 7);
  for (let d = 1; d <= remaining; d++) {
    cells += `<div class="cal-day other-month"><span class="cal-day-num">${d}</span></div>`;
  }
  grid.innerHTML = cells;
}

function renderWeekGrid(startOfWeek) {
  const grid = document.getElementById('cal-grid');
  const events = loadEvents();
  const dates = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(startOfWeek);
    d.setDate(startOfWeek.getDate() + i);
    dates.push(d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0'));
  }
  const filtered = events.filter(e => dates.includes(e.data) && (!calFilterType || e.tipo === calFilterType));
  grid.innerHTML = renderTimelineGrid(dates, filtered, 'week');
}

function renderDayView() {
  const grid = document.getElementById('cal-grid');
  const dateStr = calSelected.getFullYear() + '-' + String(calSelected.getMonth()+1).padStart(2,'0') + '-' + String(calSelected.getDate()).padStart(2,'0');
  const events = loadEvents().filter(e => e.data === dateStr && (!calFilterType || e.tipo === calFilterType));
  grid.innerHTML = renderTimelineGrid([dateStr], events, 'day');
}

