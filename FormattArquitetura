function editFinItem(id, tipo) {
  const arr  = tipo === 'receber' ? getReceber() : getPagar();
  const item = arr.find(i => i.id === id);
  if (!item) return;
  editingFinId   = id;
  editingFinType = tipo;
  document.getElementById('fi-desc').value       = item.desc;
  document.getElementById('fi-valor').value      = item.valor;
  document.getElementById('fi-data').value       = item.data || '';
  document.getElementById('fi-obs').value        = item.obs || '';
  document.getElementById('fi-tipo').value       = item.tipo;
  onFinTipoChange(document.getElementById('fi-tipo'));
  document.getElementById('fi-categoria').value  = item.categoria || '';
  document.getElementById('fi-status').value     = item.status;
  if (item.recorrencia) document.getElementById('fi-recorrencia').value = item.recorrencia;
  document.getElementById('fin-delete-btn').style.display = 'block';
  document.getElementById('fin-modal-title').textContent  = item.desc;
  document.getElementById('fin-modal').classList.add('open');
}

function saveFinItem() {
  const desc  = document.getElementById('fi-desc').value.trim();
  if (!desc) { alert('Informe a descrição'); return; }
  const item = {
    desc,
    valor:       parseFloat(document.getElementById('fi-valor').value) || 0,
    data:        document.getElementById('fi-data').value,
    tipo:        document.getElementById('fi-tipo').value,
    categoria:   document.getElementById('fi-categoria').value,
    status:      document.getElementById('fi-status').value,
    recorrencia: document.getElementById('fi-recorrencia').value || '',
    obs:         document.getElementById('fi-obs').value,
  };
  const isRec = item.tipo === 'receber-manual';
  if (isRec) {
    const arr = getReceber();
    if (editingFinId !== null) {
      const idx = arr.findIndex(i => i.id === editingFinId);
      if (idx !== -1) arr[idx] = { ...arr[idx], ...item };
    } else {
      arr.push({ id: Date.now(), ...item });
    }
    saveReceber(arr);
  } else {
    const arr = getPagar();
    if (editingFinId !== null) {
      const idx = arr.findIndex(i => i.id === editingFinId);
      if (idx !== -1) arr[idx] = { ...arr[idx], ...item };
    } else {
      arr.push({ id: Date.now(), ...item });
    }
    savePagar(arr);
  }
  closefinModal();
  renderAll();
}

function deleteFinItem() {
  if (!editingFinId || !confirm('Deletar este lançamento?')) return;
  if (editingFinType === 'receber') {
    saveReceber(getReceber().filter(i => i.id !== editingFinId));
  } else {
    savePagar(getPagar().filter(i => i.id !== editingFinId));
  }
  closefinModal();
  renderAll();
}

function labelStatus(s) {
  return { pendente:'Pendente', recebido:'Recebido', pago:'Pago', vencido:'Vencido' }[s] || s;
}

/* ════════════════════════════════════
   GRÁFICOS DE LINHA — Canvas puro
════════════════════════════════════ */

function drawLineChart(canvasId, datasets, labels, opts = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const dpr = window.devicePixelRatio || 1;
  const W   = canvas.offsetWidth  || canvas.parentElement.offsetWidth || 320;
  const H   = parseInt(canvas.getAttribute('height')) || 180;
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);

  const PAD = { top: 16, right: 16, bottom: 36, left: 60 };
  const chartW = W - PAD.left - PAD.right;
  const chartH = H - PAD.top  - PAD.bottom;

  // Calcular min/max
  const allVals = datasets.flatMap(d => d.data);
  const maxVal  = Math.max(...allVals, 1);
  const minVal  = 0;
  const range   = maxVal - minVal || 1;

  // Fundo
  ctx.fillStyle = '#fff';
  ctx.fillRect(0, 0, W, H);

  // Grid horizontal
  const gridLines = 4;
  ctx.setLineDash([4, 4]);
  ctx.strokeStyle = 'rgba(61,90,62,0.08)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= gridLines; i++) {
    const y = PAD.top + (chartH / gridLines) * i;
    ctx.beginPath(); ctx.moveTo(PAD.left, y); ctx.lineTo(PAD.left + chartW, y);
    ctx.stroke();
    // Label eixo Y
    const val = maxVal - (range / gridLines) * i;
    ctx.setLineDash([]);
    ctx.fillStyle = '#9AAA9B';
    ctx.font = `${10 * dpr / dpr}px sans-serif`;
    ctx.textAlign = 'right';
    ctx.fillText(fmtValShort(val), PAD.left - 6, y + 4);
    ctx.setLineDash([4, 4]);
  }
  ctx.setLineDash([]);

  // Eixo X — labels
  ctx.fillStyle = '#9AAA9B';
  ctx.textAlign = 'center';
  ctx.font = '10px sans-serif';
  const step = labels.length > 1 ? chartW / (labels.length - 1) : chartW;
  labels.forEach((lbl, i) => {
    const x = PAD.left + (labels.length > 1 ? i * step : chartW / 2);
    ctx.fillText(lbl, x, H - PAD.bottom + 18);
  });

  // Linha de cada dataset
  datasets.forEach(ds => {
    if (!ds.data.length) return;
    const pts = ds.data.map((v, i) => ({
      x: PAD.left + (labels.length > 1 ? i * step : chartW / 2),
      y: PAD.top + chartH - ((v - minVal) / range) * chartH,
    }));

    // Área preenchida
    ctx.beginPath();
    ctx.moveTo(pts[0].x, PAD.top + chartH);
    pts.forEach(p => ctx.lineTo(p.x, p.y));
    ctx.lineTo(pts[pts.length - 1].x, PAD.top + chartH);
    ctx.closePath();
    const grad = ctx.createLinearGradient(0, PAD.top, 0, PAD.top + chartH);
    grad.addColorStop(0, ds.color + '33');
    grad.addColorStop(1, ds.color + '05');
    ctx.fillStyle = grad;
    ctx.fill();

    // Linha
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pts[0].y);
    if (pts.length === 1) {
      ctx.arc(pts[0].x, pts[0].y, 3, 0, Math.PI * 2);
    } else {
      for (let i = 1; i < pts.length; i++) {
        // Curva suave
        const cp1x = (pts[i-1].x + pts[i].x) / 2;
        ctx.bezierCurveTo(cp1x, pts[i-1].y, cp1x, pts[i].y, pts[i].x, pts[i].y);
      }
    }
    ctx.strokeStyle = ds.color;
    ctx.lineWidth = 2.5;
    ctx.lineJoin = 'round';
    ctx.stroke();

    // Pontos
    pts.forEach(p => {
      ctx.beginPath();
      ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
      ctx.fillStyle = '#fff';
      ctx.fill();
      ctx.strokeStyle = ds.color;
      ctx.lineWidth = 2;
      ctx.stroke();
    });
  });
}

function fmtValShort(v) {
  if (v >= 1000) return 'R$' + (v/1000).toFixed(0) + 'k';
  return 'R$' + v.toFixed(0);
}

// Agrupa lançamentos por mês (últimos N meses)
function agruparPorMes(items, campo, n = 6) {
  const meses = [];
  const now = new Date();
  for (let i = n - 1; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    meses.push({
      key:   d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0'),
      label: d.toLocaleDateString('pt-BR', {month:'short', year:'2-digit'}),
      total: 0,
    });
  }
  items.forEach(item => {
    if (!item[campo]) return;
    const key = item[campo].substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.total += (item.valor || 0);
  });
  return meses;
}

/* ── Gráfico Espectro: Entradas vs Saídas por mês ── */
function renderChartEspectro() {
  const receber = getReceber();
  const pagar   = getPagar();
  const n = 6;

  const mRec = agruparPorMes(receber, 'data', n);
  const mPag = agruparPorMes(pagar,   'data', n);
  const labels = mRec.map(m => m.label);

  drawLineChart('chart-espectro', [
    { label: 'A receber', data: mRec.map(m => m.total), color: '#4A7FA5' },
    { label: 'A pagar',   data: mPag.map(m => m.total), color: '#B05A3A' },
  ], labels);

  document.getElementById('chart-espectro-legend').innerHTML = `
    <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#4A7FA5;"></div>A receber</div>
    <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#B05A3A;"></div>A pagar</div>`;
}

/* ── Gráfico Caixa: Histórico de saldo ── */
function renderChartCaixa() {
  // Gráfico de projeção
  const pd = window._projecaoData;
  if (pd) {
    let saldo = pd.saldoAtual;
    const labels = [];
    const saldos = [];
    const entradas = [];
    const saidas = [];
    pd.meses.forEach((m, i) => {
      if (i > 0) saldo += (m.entradas - m.saidas);
      labels.push(m.label);
      saldos.push(saldo);
      entradas.push(m.entradas);
      saidas.push(m.saidas);
    });
    drawLineChart('chart-projecao', [
      { label: 'Saldo projetado', data: saldos,   color: '#3B5436' },
      { label: 'Entradas',        data: entradas,  color: '#4A7FA5' },
      { label: 'Saídas',          data: saidas,    color: '#B05A3A' },
    ], labels);
    document.getElementById('chart-projecao-legend').innerHTML = `
      <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#3B5436;"></div>Saldo projetado</div>
      <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#4A7FA5;"></div>Entradas</div>
      <div class="chart-leg-item"><div class="chart-leg-dot" style="background:#B05A3A;"></div>Saídas</div>`;
  }

  // Gráfico de histórico de saldo
  const hist = JSON.parse(localStorage.getItem('fa-fin-saldo-hist') || '[]');
  if (hist.length < 2) {
    const canvas = document.getElementById('chart-caixa');
    if (!canvas) return;
    const W = canvas.offsetWidth || 320, H = 160;
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#fff'; ctx.fillRect(0,0,W,H);
    ctx.fillStyle = '#9AAA9B'; ctx.font = '12px sans-serif'; ctx.textAlign = 'center';
    ctx.fillText('Atualize o saldo algumas vezes para ver a evolução', W/2, H/2);
    return;
  }
  drawLineChart('chart-caixa', [
    { label: 'Saldo', data: hist.map(h => h.valor), color: '#3B5436' },
  ], hist.map(h => fmtDateShort(h.data)));
}

/* ── Gráfico A Receber: entradas por vencimento ── */
function renderChartReceber() {
  const meses = agruparPorMes(getReceber(), 'data', 6);
  drawLineChart('chart-receber', [
    { label: 'A receber', data: meses.map(m => m.total), color: '#4A7FA5' },
  ], meses.map(m => m.label));
  document.getElementById('chart-receber-legend').innerHTML =
    '<div class="chart-leg-item"><div class="chart-leg-dot" style="background:#4A7FA5;"></div>Valor a receber por mês</div>';
}

/* ── Gráfico A Pagar: despesas por vencimento ── */
function renderChartPagar() {
  const meses = agruparPorMes(getPagar(), 'data', 6);
  drawLineChart('chart-pagar', [
    { label: 'A pagar', data: meses.map(m => m.total), color: '#B05A3A' },
  ], meses.map(m => m.label));
  document.getElementById('chart-pagar-legend').innerHTML =
    '<div class="chart-leg-item"><div class="chart-leg-dot" style="background:#B05A3A;"></div>Despesas por mês</div>';
}

function fmtDateShort(d) {
  if (!d) return '';
  return new Date(d + 'T12:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short'});
}

/* ── START ── */
renderAll();
</script>

</div>
<script>
// === MÓDULO FINANCEIRO ===
(function() {

/* ═══════════════════════════════════════════════
   FINANCEIRO — módulo standalone
   localStorage keys:
     fa-fin-saldo     → number
     fa-fin-receber   → array (manuais)
     fa-fin-pagar     → array (fixos + avulsos)
═══════════════════════════════════════════════ */

const SALDO_KEY   = 'fa-fin-saldo';
const RECEBER_KEY = 'fa-fin-receber';
const PAGAR_KEY   = 'fa-fin-pagar';
const PROJ_KEY    = 'fa-projetos-v1';

let editingFinId   = null;
let editingFinType = null;

/* ── STORAGE ── */
function getSaldo()   { return parseFloat(localStorage.getItem(SALDO_KEY) || '0'); }
function getReceber() { try { return JSON.parse(localStorage.getItem(RECEBER_KEY) || '[]'); } catch { return []; } }
function getPagar()   { try { return JSON.parse(localStorage.getItem(PAGAR_KEY) || '[]'); } catch { return []; } }
function getProjetos(){ try { return JSON.parse(localStorage.getItem(PROJ_KEY)    || '[]'); } catch { return []; } }

function saveSaldoData(v) { localStorage.setItem(SALDO_KEY, v); }
function saveReceber(d)   { localStorage.setItem(RECEBER_KEY, JSON.stringify(d)); }
function savePagar(d)     { localStorage.setItem(PAGAR_KEY,   JSON.stringify(d)); }

/* ── SEED (primeira abertura) ── */
(function() {
  if (!localStorage.getItem(RECEBER_KEY)) {
    saveReceber([
      { id: 1001, desc: 'Honorários Ana Paula Lima — parcela 1', valor: 6000, data: '2025-06-10', tipo: 'receber-manual', categoria: 'honorarios', status: 'recebido', obs: '' },
      { id: 1002, desc: 'Honorários Marcos Braga — parcela 1',   valor: 3167, data: '2025-06-20', tipo: 'receber-manual', categoria: 'honorarios', status: 'pendente', obs: '' },
    ]);
  }
  if (!localStorage.getItem(PAGAR_KEY)) {
    savePagar([
      { id: 2001, desc: 'Aluguel do escritório',  valor: 2200, data: '2025-06-05', tipo: 'pagar-fixo', categoria: 'aluguel',    recorrencia: 'mensal', status: 'pago',     obs: '' },
      { id: 2002, desc: 'Adobe Creative Cloud',   valor: 349,  data: '2025-06-15', tipo: 'pagar-fixo', categoria: 'software',   recorrencia: 'mensal', status: 'pendente', obs: '' },
      { id: 2003, desc: 'Impressão de pranchas',  valor: 420,  data: '2025-06-18', tipo: 'pagar-avulso', categoria: 'fornecedor', recorrencia: '', status: 'pendente', obs: 'Projeto Horizonte' },
    ]);
  }
})();

/* ── FORMATAÇÃO ── */
const fmtVal  = v => 'R$ ' + Number(v || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
const fmtDate = d => d ? new Date(d + 'T12:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short', year:'2-digit'}) : '—';

/* ── TABS ── */
function switchFinTab(tab, btn) {
  document.querySelectorAll('.fin-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.fin-section').forEach(s => s.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('sec-' + tab).classList.add('active');
  if (tab === 'espectro') renderEspectro();
  if (tab === 'caixa')    renderCaixa();
  if (tab === 'receber')  renderReceber();
  if (tab === 'pagar')    renderPagar();
  // Redraw chart para a aba ativa
  setTimeout(() => {
    if (tab === 'espectro') renderChartEspectro();
    if (tab === 'caixa')    renderChartCaixa();
    if (tab === 'receber')  renderChartReceber();
    if (tab === 'pagar')    renderChartPagar();
  }, 30);
}

/* ── RENDER ALL ── */
function renderAll() {
  renderEspectro();
  renderCaixa();
  renderReceber();
  renderPagar();
  // Gráficos com delay para garantir layout pronto
  setTimeout(() => {
    renderChartEspectro();
    renderChartCaixa();
    renderChartReceber();
    renderChartPagar();
  }, 50);
}

/* ══ CAIXA ══ */
function renderCaixa() {
  const saldo = getSaldo();
  document.getElementById('caixa-valor-display').textContent = fmtVal(saldo);

  // Projeção mensal
  renderProjecaoCaixa(saldo);

  // Histórico
  const hist = JSON.parse(localStorage.getItem('fa-fin-saldo-hist') || '[]');
  const wrap = document.getElementById('caixa-historico');
  if (!hist.length) {
    wrap.innerHTML = '<div class="fin-empty">Nenhuma atualização registrada ainda.</div>';
    return;
  }
  wrap.innerHTML = hist.slice(-5).reverse().map(h => `
    <div class="fin-item" style="cursor:default;">
      <div class="fin-item-dot" style="background:var(--verde);"></div>
      <div class="fin-item-info">
        <div class="fin-item-desc">${h.obs || 'Saldo atualizado'}</div>
        <div class="fin-item-meta">${fmtDate(h.data)}</div>
      </div>
      <div class="fin-item-val" style="color:var(--verde);">${fmtVal(h.valor)}</div>
    </div>`).join('');
}

function renderProjecaoCaixa(saldoAtual) {
  const receber  = getReceber();
  const pagar    = getPagar();
  const projetos = getProjetos().filter(p => p.status === 'andamento' && p.valor > 0);
  const MESES_LABEL = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const N = 6; // próximos 6 meses
  const now = new Date();

  // Monta array de meses futuros (incluindo o mês atual)
  const meses = [];
  for (let i = 0; i < N; i++) {
    const d   = new Date(now.getFullYear(), now.getMonth() + i, 1);
    const key = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
    meses.push({ key, label: MESES_LABEL[d.getMonth()] + '/' + String(d.getFullYear()).slice(2), entradas: 0, saidas: 0 });
  }

  // Soma entradas por mês (a receber manuais pendentes)
  receber.filter(r => r.status !== 'recebido').forEach(r => {
    if (!r.data) return;
    const key = r.data.substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.entradas += (r.valor || 0);
  });

  // Soma entradas dos projetos (usa mês de entrega como referência)
  projetos.forEach(p => {
    const ref = p.entrega || '';
    if (!ref) return;
    const key = ref.substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.entradas += (p.valor || 0);
  });

  // Soma saídas por mês (a pagar pendentes)
  pagar.filter(p => p.status !== 'pago').forEach(p => {
    if (!p.data) return;
    const key = p.data.substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.saidas += (p.valor || 0);
    // Despesas fixas mensais: propaga para os meses seguintes se recorrente
    if (p.tipo === 'pagar-fixo' && p.recorrencia === 'mensal') {
      meses.forEach(mes => {
        if (mes.key !== key) mes.saidas += (p.valor || 0);
      });
    }
  });

  // Calcula saldo acumulado mês a mês
  let saldoAcum = saldoAtual;
  const projList = document.getElementById('caixa-projecao-list');
  const now_key  = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');

  projList.innerHTML = meses.map((m, i) => {
    const delta   = m.entradas - m.saidas;
    if (i > 0) saldoAcum += delta;
    const isAtual = m.key === now_key;
    const pos     = saldoAcum >= 0;
    return `
      <div class="proj-mes-item ${pos ? 'positivo' : 'negativo'} ${isAtual ? 'proj-mes-atual' : ''}">
        <div class="proj-mes-nome">${m.label}${isAtual ? ' <span style="font-size:10px;color:var(--muted);font-weight:400;">· mês atual</span>' : ''}</div>
        <div class="proj-mes-saldo ${pos ? 'positivo' : 'negativo'}">${fmtVal(saldoAcum)}</div>
        <div class="proj-mes-detalhe">
          ${m.entradas ? `<span style="color:#4A7FA5;">▲ ${fmtVal(m.entradas)}</span>` : ''}
          ${m.entradas && m.saidas ? ' &nbsp;' : ''}
          ${m.saidas ? `<span style="color:#B05A3A;">▼ ${fmtVal(m.saidas)}</span>` : ''}
          ${!m.entradas && !m.saidas ? '<span>Sem lançamentos previstos</span>' : ''}
        </div>
      </div>`;
  }).join('');

  // Guarda dados para o gráfico
  window._projecaoData = { meses, saldoAtual };
}

function openSaldoModal() {
  document.getElementById('saldo-input').value = getSaldo();
  document.getElementById('saldo-modal').classList.add('open');
  setTimeout(() => document.getElementById('saldo-input').focus(), 100);
}

function saveSaldo() {
  const val = parseFloat(document.getElementById('saldo-input').value) || 0;
  saveSaldoData(val);
  // Guarda no histórico
  const hist = JSON.parse(localStorage.getItem('fa-fin-saldo-hist') || '[]');
  hist.push({ valor: val, data: new Date().toISOString().split('T')[0], obs: 'Saldo atualizado' });
  localStorage.setItem('fa-fin-saldo-hist', JSON.stringify(hist));
  document.getElementById('saldo-modal').classList.remove('open');
  renderAll();
}

/* ══ A RECEBER ══ */
function renderReceber() {
  const manuais  = getReceber();
  const projetos = getProjetos().filter(p => p.status === 'andamento' && p.valor > 0);

  // Total: projetos em andamento com status pendente + manuais pendentes
  const totalProjetos = projetos.reduce((s, p) => s + (p.valor || 0), 0);
  const totalManuais  = manuais.filter(r => r.status === 'pendente' || r.status === 'vencido')
                               .reduce((s, r) => s + (r.valor || 0), 0);
  const totalGeral    = totalProjetos + totalManuais;
  const countPend     = projetos.length + manuais.filter(r => r.status !== 'recebido').length;

  document.getElementById('receber-total-display').textContent = fmtVal(totalGeral);
  document.getElementById('receber-sub').textContent = countPend + ' lançamento' + (countPend !== 1 ? 's' : '') + ' pendente' + (countPend !== 1 ? 's' : '');

  // Projetos em andamento
  const projList = document.getElementById('receber-projetos-list');
  if (!projetos.length) {
    projList.innerHTML = '<div class="fin-empty" style="padding:12px 0;">Nenhum projeto em andamento com valor definido.</div>';
  } else {
    projList.innerHTML = projetos.map(p => {
      const tipos = Array.isArray(p.tipo) ? p.tipo.join(' · ') : (p.tipo || '—');
      return `
      <div class="fin-item" style="cursor:default;">
        <div class="fin-item-dot" style="background:var(--receber-cor);"></div>
        <div class="fin-item-info">
          <div class="fin-item-desc">${p.cliente}</div>
          <div class="fin-item-meta">${tipos}${p.entrega ? ' · Entrega ' + fmtDate(p.entrega) : ''}</div>
        </div>
        <div class="fin-item-val receber">${fmtVal(p.valor)}</div>
      </div>`;
    }).join('');
  }

  // Manuais
  const manList = document.getElementById('receber-manual-list');
  if (!manuais.length) {
    manList.innerHTML = '<div class="fin-empty" style="padding:12px 0;">Nenhum lançamento manual.</div>';
  } else {
    manList.innerHTML = manuais.map(r => `
      <div class="fin-item" onclick="editFinItem(${r.id},'receber')">
        <div class="fin-item-dot" style="background:var(--receber-cor);"></div>
        <div class="fin-item-info">
          <div class="fin-item-desc">${r.desc}</div>
          <div class="fin-item-meta">
            ${fmtDate(r.data)}
            <span class="fin-item-status status-${r.status}">${labelStatus(r.status)}</span>
          </div>
        </div>
        <div class="fin-item-val receber">${fmtVal(r.valor)}</div>
      </div>`).join('');
  }
}

/* ══ A PAGAR ══ */
function renderPagar() {
  const todos   = getPagar();
  const fixos   = todos.filter(p => p.tipo === 'pagar-fixo');
  const avulsos = todos.filter(p => p.tipo === 'pagar-avulso');

  const totalPend = todos.filter(p => p.status !== 'pago')
                         .reduce((s, p) => s + (p.valor || 0), 0);
  const countPend = todos.filter(p => p.status !== 'pago').length;

  document.getElementById('pagar-total-display').textContent = fmtVal(totalPend);
  document.getElementById('pagar-sub').textContent = countPend + ' despesa' + (countPend !== 1 ? 's' : '') + ' pendente' + (countPend !== 1 ? 's' : '');

  renderPagarList('pagar-fixo-list', fixos);
  renderPagarList('pagar-avulso-list', avulsos);
}

function renderPagarList(elId, list) {
  const wrap = document.getElementById(elId);
  if (!list.length) {
    wrap.innerHTML = '<div class="fin-empty" style="padding:12px 0;">Nenhuma despesa.</div>';
    return;
  }
  wrap.innerHTML = list.map(p => `
    <div class="fin-item" onclick="editFinItem(${p.id},'pagar')">
      <div class="fin-item-dot" style="background:var(--pagar-cor);"></div>
      <div class="fin-item-info">
        <div class="fin-item-desc">${p.desc}</div>
        <div class="fin-item-meta">
          ${fmtDate(p.data)}${p.recorrencia ? ' · ' + p.recorrencia : ''}
          <span class="fin-item-status ${p.tipo === 'pagar-fixo' ? 'status-fixo' : 'status-' + p.status}">${p.tipo === 'pagar-fixo' ? 'Fixo' : labelStatus(p.status)}</span>
        </div>
      </div>
      <div class="fin-item-val pagar">${fmtVal(p.valor)}</div>
    </div>`).join('');
}

/* ══ ESPECTRO GERAL ══ */
function renderEspectro() {
  const saldo    = getSaldo();
  const receber  = getReceber();
  const pagar    = getPagar();
  const projetos = getProjetos().filter(p => p.status === 'andamento' && p.valor > 0);

  const totalReceber = projetos.reduce((s,p) => s+(p.valor||0), 0)
                     + receber.filter(r => r.status !== 'recebido').reduce((s,r) => s+(r.valor||0), 0);
  const totalPagar   = pagar.filter(p => p.status !== 'pago').reduce((s,p) => s+(p.valor||0), 0);
  const saldoFuturo  = saldo + totalReceber - totalPagar;
  const totalMovim   = totalReceber + totalPagar;

  const pctRec = totalMovim > 0 ? totalReceber / totalMovim * 100 : 50;
  const pctPag = totalMovim > 0 ? totalPagar   / totalMovim * 100 : 50;

  const recebMes    = receber.filter(r => r.status === 'recebido').reduce((s,r) => s+(r.valor||0), 0);
  const pagoMes     = pagar.filter(p => p.status === 'pago').reduce((s,p) => s+(p.valor||0), 0);
  const qtdVencidos = [...receber, ...pagar].filter(i => i.status === 'vencido').length;

  const el = document.getElementById('espectro-content');
  el.innerHTML = `
    <!-- Saldo + balanço -->
    <div class="resumo-card verde" style="margin-bottom:16px;">
      <div class="resumo-label">Saldo atual em caixa</div>
      <div class="resumo-valor">${fmtVal(saldo)}</div>
      <div class="resumo-sub">Projeção futura: <strong>${fmtVal(saldoFuturo)}</strong></div>
      <button class="resumo-edit-btn" onclick="openSaldoModal()">Editar</button>
    </div>

    <!-- Barra visual -->
    <div class="espectro-bar-wrap">
      <div class="espectro-bar-title">Entradas vs Saídas</div>
      <div class="esp-bar">
        <div class="esp-seg entradas" style="width:${pctRec.toFixed(1)}%;"></div>
        <div class="esp-seg saidas"   style="width:${pctPag.toFixed(1)}%;"></div>
      </div>
      <div class="esp-legend">
        <div class="esp-leg-item"><div class="esp-leg-dot" style="background:var(--receber-cor);"></div><span class="esp-leg-label">A receber</span>&nbsp;<span class="esp-leg-val">${fmtVal(totalReceber)}</span></div>
        <div class="esp-leg-item"><div class="esp-leg-dot" style="background:var(--pagar-cor);"></div><span class="esp-leg-label">A pagar</span>&nbsp;<span class="esp-leg-val">${fmtVal(totalPagar)}</span></div>
      </div>
    </div>

    <!-- Grid de cards -->
    <div class="espectro-grid">
      <div class="esp-card">
        <div class="esp-card-label">A receber</div>
        <div class="esp-card-val azul">${fmtVal(totalReceber)}</div>
        <div class="esp-card-sub">${projetos.length + receber.filter(r=>r.status!=='recebido').length} pendentes</div>
      </div>
      <div class="esp-card">
        <div class="esp-card-label">A pagar</div>
        <div class="esp-card-val vermelho">${fmtVal(totalPagar)}</div>
        <div class="esp-card-sub">${pagar.filter(p=>p.status!=='pago').length} pendentes</div>
      </div>
      <div class="esp-card">
        <div class="esp-card-label">Recebido</div>
        <div class="esp-card-val verde">${fmtVal(recebMes)}</div>
        <div class="esp-card-sub">lançamentos pagos</div>
      </div>
      <div class="esp-card">
        <div class="esp-card-label">Pago</div>
        <div class="esp-card-val neutro">${fmtVal(pagoMes)}</div>
        <div class="esp-card-sub">despesas pagas</div>
      </div>
    </div>

    ${qtdVencidos > 0 ? `
    <div style="background:#FDECEA;border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:10px;margin-bottom:16px;">
      <span style="font-size:18px;">⚠️</span>
      <div>
        <div style="font-size:13px;font-weight:600;color:#B03A2A;">${qtdVencidos} lançamento${qtdVencidos>1?'s':''} vencido${qtdVencidos>1?'s':''}</div>
        <div style="font-size:11px;color:#B03A2A;opacity:.8;">Verifique as abas A Receber e A Pagar</div>
