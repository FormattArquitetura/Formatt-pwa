/* ── TABS ── */
let tabAtiva = 'empresa';
function switchTab(tab, btn) {
 document.querySelectorAll('.inst-tab').forEach(b=>b.classList.remove('active'));
 document.querySelectorAll('.inst-section').forEach(s=>s.classList.remove('active'));
 btn.classList.add('active');
 document.getElementById('sec-'+tab).classList.add('active');
 tabAtiva = tab;
 renderTab(tab);
}

function renderTab(tab) {
 if(tab==='empresa') renderEmpresa();
 if(tab==='equipe') renderEquipe();
 if(tab==='documentos') renderDocumentos();
 if(tab==='contatos') renderContatos();
 if(tab==='ferramentas') renderFerramentas();
