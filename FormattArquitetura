function editServicos() {
 const e = load(KEYS.empresa)||{};
 const servs = (e.servicos||[]).join('\n');
 openModal('Serviços oferecidos',
 `<div class="field">
 <label class="field-label">Um serviço por linha</label>
 <textarea class="field-input field-textarea" id="edit-servicos" style="min-height:140px;">${servs}</textarea>
 </div>
 <button class="save-btn" onclick="_saveModal()"> Salvar</button>`,
 () => {
 const e = load(KEYS.empresa)||{};
 e.servicos = val('edit-servicos').split('\n').map(s=>s.trim()).filter(Boolean);
 save(KEYS.empresa, e);
 closeModal(); renderEmpresa();
 }
 );
}

