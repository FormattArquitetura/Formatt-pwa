        <div class="day-panel-info">
          <div class="day-panel-title">${e.titulo}</div>
          <div class="day-panel-meta">${e.hora ? e.hora + (e.horaFim ? ' – ' + e.horaFim : '') : ''}${e.local ? ' · ' + e.local : ''}</div>
        </div>
      </div>`).join('');

  const overlay = document.getElementById('day-panel-overlay');
  overlay.classList.add('open');
}

function closeDayPanel() {
  document.getElementById('day-panel-overlay').classList.remove('open');
}

/* ── MODAL NOVO EVENTO ── */
function openCalModal() {
  const ds = calSelected.getFullYear() + '-' + String(calSelected.getMonth()+1).padStart(2,'0') + '-' + String(calSelected.getDate()).padStart(2,'0');
  document.getElementById('cf-titulo').value = '';
  document.getElementById('cf-tipo').value = 'reuniao-online';
  document.getElementById('cf-data').value = ds;
  document.getElementById('cf-hora').value = '';
  document.getElementById('cf-hora-fim').value = '';
  document.getElementById('cf-local').value = '';
  document.getElementById('cf-obs').value = '';
  document.getElementById('cf-custom-fields').style.display = 'none';
  document.getElementById('cal-modal').classList.add('open');
}
function closeCalModal(e) {
  if (e.target === document.getElementById('cal-modal')) document.getElementById('cal-modal').classList.remove('open');
}
function saveCalEvent() {
  const tipoSel = document.getElementById('cf-tipo').value;
  if (tipoSel === 'outro') {
    const nome = document.getElementById('cf-custom-nome').value.trim();
    if (!nome) { alert('Informe o nome do novo tipo'); return; }
    const id = 'custom-' + nome.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    const novoTipo = { id, nome, color: selectedCustomColor, border: selectedCustomBorder };
    const tipos = loadCustomTipos();
    if (!tipos.find(t => t.id === id)) { tipos.push(novoTipo); saveCustomTipos(tipos); addCustomTipoToSidebar(novoTipo); }
    document.getElementById('cf-tipo').value = id;
  }
  const titulo = document.getElementById('cf-titulo').value.trim();
  if (!titulo) { alert('Informe o título'); return; }
  const events = loadEvents();
  events.push({
    id: Date.now(), titulo,
    tipo: document.getElementById('cf-tipo').value,
    data: document.getElementById('cf-data').value,
    hora: document.getElementById('cf-hora').value,
    horaFim: document.getElementById('cf-hora-fim').value,
    local: document.getElementById('cf-local').value,
    obs: document.getElementById('cf-obs').value,
  });
  saveEvents(events);
  document.getElementById('cal-modal').classList.remove('open');
  document.getElementById('cf-custom-fields').style.display = 'none';
  renderCalendar();
}

/* ── MODAL EDITAR EVENTO ── */
function openEditEventModal(eventId) {
  const ev = loadEvents().find(e => e.id === eventId);
  if (!ev) return;
  editingEventId = eventId;
  const sel = document.getElementById('ef-tipo');
  loadCustomTipos().forEach(t => {
    if (!sel.querySelector('option[value="'+t.id+'"]')) {
      const opt = document.createElement('option');
      opt.value = t.id; opt.textContent = t.nome;
      sel.appendChild(opt);
    }
  });
  document.getElementById('ef-id').value = ev.id;
  document.getElementById('ef-titulo').value = ev.titulo || '';
  document.getElementById('ef-tipo').value = ev.tipo || 'reuniao-online';
  document.getElementById('ef-data').value = ev.data || '';
  document.getElementById('ef-hora').value = ev.hora || '';
  document.getElementById('ef-hora-fim').value = ev.horaFim || '';
  document.getElementById('ef-local').value = ev.local || '';
  document.getElementById('ef-obs').value = ev.obs || '';
  document.getElementById('edit-modal-title').textContent = ev.titulo;
  document.getElementById('edit-modal').classList.add('open');
}
function saveEditCalEvent() {
  const titulo = document.getElementById('ef-titulo').value.trim();
  if (!titulo) { alert('Informe o título'); return; }
  const events = loadEvents();
  const idx = events.findIndex(e => e.id === editingEventId);
  if (idx === -1) return;
  events[idx] = {
    ...events[idx], titulo,
    tipo: document.getElementById('ef-tipo').value,
    data: document.getElementById('ef-data').value,
    hora: document.getElementById('ef-hora').value,
    horaFim: document.getElementById('ef-hora-fim').value,
    local: document.getElementById('ef-local').value,
    obs: document.getElementById('ef-obs').value,
  };
  saveEvents(events);
  document.getElementById('edit-modal').classList.remove('open');
  renderCalendar();
}
function deleteCalEvent() {
  if (!confirm('Deletar este compromisso?')) return;
  saveEvents(loadEvents().filter(e => e.id !== editingEventId));
  document.getElementById('edit-modal').classList.remove('open');
  renderCalendar();
}

/* ── CUSTOM TIPO ── */
function onTipoChange(sel) {
  document.getElementById('cf-custom-fields').style.display = sel.value === 'outro' ? 'block' : 'none';
}
function selectColor(el) {
  document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  selectedCustomColor = el.dataset.color;
  selectedCustomBorder = el.dataset.border;
}
function addCustomTipoToSidebar(tipo) {
  const legend = document.querySelector('.agenda-legend');
  const allBtn = document.getElementById('leg-all');
  if (!legend || !allBtn || document.getElementById('leg-' + tipo.id)) return;
  const item = document.createElement('div');
  item.className = 'agenda-legend-item';
  item.id = 'leg-' + tipo.id;
  item.onclick = () => filterByType(tipo.id);
  item.innerHTML = `<div class="agenda-legend-dot" style="background:${tipo.color};border:2px solid ${tipo.border};"></div><span class="agenda-legend-label">${tipo.nome}</span>`;
  legend.insertBefore(item, allBtn);
  const style = document.createElement('style');
  style.textContent = `.cal-event-item[data-tipo="${tipo.id}"] { border-left-color: ${tipo.border}; background: ${tipo.color}22; }`;
  document.head.appendChild(style);
  const sel = document.getElementById('cf-tipo');
  if (sel) {
    const opt = document.createElement('option');
    opt.value = tipo.id; opt.textContent = tipo.nome;
    sel.insertBefore(opt, sel.querySelector('option[value="outro"]'));
  }
}
function initCustomTipos() {
  loadCustomTipos().forEach(addCustomTipoToSidebar);
}
function getTipoLabel(tipoId) {
  return TIPO_LABELS[tipoId] || (loadCustomTipos().find(t => t.id === tipoId) || {}).nome || tipoId;
}

/* ── QUICK ADD (timeline click) ── */
function quickAddEvent(dateStr, hora) {
  document.getElementById('cf-data').value = dateStr;
  document.getElementById('cf-hora').value = hora;
  document.getElementById('cf-hora-fim').value = '';
  document.getElementById('cf-titulo').value = '';
  document.getElementById('cf-tipo').value = 'reuniao-online';
  document.getElementById('cf-local').value = '';
  document.getElementById('cf-obs').value = '';
  document.getElementById('cf-custom-fields').style.display = 'none';
  document.getElementById('cal-modal').classList.add('open');
}

/* ── TIMELINE ── */
const TL_START = 8, TL_END = 20;
const TL_SLOTS = (TL_END - TL_START) * 2;

function renderTimelineGrid(dates, events, mode) {
  const today = new Date();
  const isWeek = mode === 'week';
  let headerHTML = '';
  if (isWeek) {
    headerHTML = `<div class="tl-header-row"><div class="tl-time-gutter"></div>${dates.map(ds => {
      const d = new Date(ds + 'T12:00');
      const isToday = d.toDateString() === today.toDateString();
      return `<div class="tl-day-head${isToday?' tl-today':''}"><span class="tl-day-head-name">${DAYS_SHORT[d.getDay()]}</span><span class="tl-day-head-num">${d.getDate()}</span></div>`;
    }).join('')}</div>`;
  } else {
    const d = new Date(dates[0] + 'T12:00');
    headerHTML = `<div class="tl-day-solo-head">${DAYS_SHORT[d.getDay()]}, ${d.getDate()} de ${MONTHS[d.getMonth()]}</div>`;
  }

  let slotsHTML = '<div class="tl-body">';
  slotsHTML += `<div class="tl-time-col" style="display:grid;grid-template-rows:repeat(${TL_SLOTS},1fr);width:48px;flex-shrink:0;border-right:1px solid var(--borda);">`;
  for (let s = 0; s < TL_SLOTS; s++) {
    const h = TL_START + Math.floor(s/2), m = s%2===0?'00':'30';
    slotsHTML += `<div class="tl-slot-label ${m==='00'?'tl-hour':'tl-half'}" style="grid-row:${s+1};">${m==='00'?String(h).padStart(2,'0')+':00':''}</div>`;
  }
  slotsHTML += '</div>';

  const TIPO_BG = {'reuniao-online':'#A8C8F0','reuniao-presencial':'#FBBF8A','visita-tecnica':'#FDE68A','dedicacao-formatt':'#A8D5B0'};
  const TIPO_BD = {'reuniao-online':'#7AAEE0','reuniao-presencial':'#F0A060','visita-tecnica':'#F0CC50','dedicacao-formatt':'#78B888'};
  function getColor(tipo, prop) {
    const base = prop==='bg' ? TIPO_BG : TIPO_BD;
    if (base[tipo]) return base[tipo];
    const ct = loadCustomTipos().find(t=>t.id===tipo);
    return ct ? (prop==='bg'?ct.color:ct.border) : '#E0E0E0';
  }
  function timeToSlot(t) { const [h,m]=t.split(':').map(Number); return (h-TL_START)*2+(m>=30?1:0); }
  function computeColumns(dayEvs) {
    const layouts = dayEvs.map(e => {
      const s = timeToSlot(e.hora); if (s<0||s>=TL_SLOTS) return null;
      let end = s+1;
      if(e.horaFim){const es=timeToSlot(e.horaFim);if(es>s)end=Math.min(es,TL_SLOTS);}
      return {e,s,end,col:0,total:1};
    }).filter(Boolean);
    layouts.forEach((ev,i)=>{
      const overlaps=layouts.slice(0,i).filter(o=>o.s<ev.end&&o.end>ev.s);
      if(overlaps.length){const used=overlaps.map(o=>o.col);let col=0;while(used.includes(col))col++;ev.col=col;const maxTotal=Math.max(...overlaps.map(o=>o.total),col+1);ev.total=maxTotal;overlaps.forEach(o=>{if(o.total<maxTotal)o.total=maxTotal;});}
    });
    return layouts;
  }

  dates.forEach(ds => {
    const d = new Date(ds+'T12:00');
    const isToday = d.toDateString()===today.toDateString();
    const dayEvents = events.filter(e=>e.data===ds&&e.hora);
    const layouts = computeColumns(dayEvents);
    slotsHTML += `<div class="tl-day-col${isToday?' tl-today-col':''}" style="display:grid;grid-template-rows:repeat(${TL_SLOTS},1fr);position:relative;">`;
    for(let s=0;s<TL_SLOTS;s++){
      const h=TL_START+Math.floor(s/2),m=s%2===0?'00':'30',ts=String(h).padStart(2,'0')+':'+m;
      slotsHTML+=`<div class="tl-slot ${m==='00'?'tl-slot-hour':'tl-slot-half'}" style="grid-row:${s+1};" onclick="quickAddEvent('${ds}','${ts}')"></div>`;
    }
    layouts.forEach(({e,s:startSlot,end:endSlot,col:evCol,total})=>{
      const span=endSlot-startSlot;
      const topPct=(startSlot/TL_SLOTS*100).toFixed(2);
      const hPct=(span/TL_SLOTS*100).toFixed(2);
      const leftPct=(evCol/total*100).toFixed(2);
      const widPct=(1/total*100).toFixed(2);
      slotsHTML+=`<div class="tl-event-abs" style="position:absolute;top:${topPct}%;height:${hPct}%;left:calc(${leftPct}% + 1px);width:calc(${widPct}% - 3px);background:${getColor(e.tipo,'bg')};border-left:3px solid ${getColor(e.tipo,'border')};z-index:2;cursor:pointer;" onclick="event.stopPropagation();openEditEventModal(${e.id})"><span class="tl-event-time">${e.hora}${e.horaFim?'–'+e.horaFim:''}</span><span class="tl-event-title">${e.titulo}</span></div>`;
    });
    slotsHTML+='</div>';
  });
  slotsHTML+='</div>';
  return headerHTML+`<div class="tl-scroll-wrap">${slotsHTML}</div>`;
}

/* ── START ── */
initCalendar();
</script>

