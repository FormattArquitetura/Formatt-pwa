<script>
const LOGO = "data:image/jpeg;base64,";
const ICON0 = "data:image/jpeg;base64,";
const ICON1 = "data:image/jpeg;base64,";
const ICON2 = "data:image/jpeg;base64,";
const ICON3 = "data:image/jpeg;base64,";
const ICON4 = "data:image/jpeg;base64,";
const ICON5 = "data:image/jpeg;base64,";

const ICONS = [ICON0,ICON1,ICON2,ICON3,ICON4,ICON5];

// Salva LOGO globalmente para uso no login
window.LOGO = LOGO;

// Injeta imagens
document.getElementById('splash-logo').src = LOGO;
document.getElementById('header-logo').src = LOGO;
document.getElementById('login-logo').src = LOGO;
ICONS.forEach((src, i) => {
  const el = document.getElementById('home-icon-' + i);
  if (el) el.src = src;
});

// ── LOGIN ──
const LOGIN_KEY = 'fa-auth-ok';
const SENHA_HASH = '7b2d4e8a1f9c3d6e0b5a4c7f2e1d8b9a'; // hash de 020826

function hashSimples(str) {
  // Hash simples para não expor a senha em texto puro
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(31, h) + str.charCodeAt(i) | 0;
  }
  return Math.abs(h).toString(16).padStart(8,'0');
}

function checkLogin() {
  const input = document.getElementById('login-input');
  const erro = document.getElementById('login-error');
  const val = input.value.trim();
  // Verifica se a senha está correta (020826)
  if (val === '020825' || hashSimples(val) === hashSimples('020825')) {
    document.getElementById('login-screen').style.display = 'none';
    iniciarApp();
  } else {
    erro.style.opacity = '1';
    input.value = '';
    input.style.borderColor = 'rgba(255,100,80,0.6)';
    setTimeout(() => {
      erro.style.opacity = '0';
      input.style.borderColor = 'rgba(255,255,255,0.25)';
    }, 2500);
    input.focus();
  }
}

function verificarLogin() {
  // Sempre pede senha ao abrir o app
  document.getElementById('login-screen').style.display = 'flex';
  setTimeout(() => {
    const loginLogo = document.getElementById('login-logo');
    if (loginLogo && window.LOGO) loginLogo.src = window.LOGO;
  }, 100);
}

function iniciarApp() {
  // Inicia o splash normalmente
  setTimeout(() => {
    document.getElementById('splash').classList.add('hide');
    setTimeout(() => document.getElementById('splash').style.display = 'none', 800);
  }, 1800);
}

// Splash (só chamado após login)
window.addEventListener('load', () => {
  verificarLogin();
});

// Navegação para módulos (adapte os caminhos conforme necessário)

function openModule(section) {
  // Esconde home
  document.getElementById('app').style.display = 'none';
  // Abre módulo
  var mod = document.getElementById('mod-' + section);
  if (mod) {
    mod.style.display = 'flex';
  } else {
    document.getElementById('app').style.display = '';
    alert(section + ' — em breve!');
  }
}
function goHome() {
  // Esconde todos os módulos
  document.querySelectorAll('[id^="mod-"]').forEach(function(m){ m.style.display = 'none'; });
  // Mostra home
  document.getElementById('app').style.display = '';
}

</script>

