/* ── TIMELINE ── */
const TL_START = 8, TL_END = 20;
const TL_SLOTS = (TL_END - TL_START) * 2;

function renderTimelineGrid(dates, events, mode) {
  const today = new Date();
  const isWeek = mode === 'week';
  let headerHTML = '';
  if (isWeek) {
    headerHTML = `<div class="tl-header-row"><div class="tl-time-gutter"></div>${dates.map(ds => {
      const d = new Date(ds + 'T12:00');
      const isToday = d.toDateString() === today.toDateString();
      return `<div class="tl-day-head${isToday?' tl-today':''}"><span class="tl-day-head-name">${DAYS_SHORT[d.getDay()]}</span><span class="tl-day-head-num">${d.getDate()}</span></div>`;
    }).join('')}</div>`;
  } else {
    const d = new Date(dates[0] + 'T12:00');
    headerHTML = `<div class="tl-day-solo-head">${DAYS_SHORT[d.getDay()]}, ${d.getDate()} de ${MONTHS[d.getMonth()]}</div>`;
  }

  let slotsHTML = '<div class="tl-body">';
  slotsHTML += `<div class="tl-time-col" style="display:grid;grid-template-rows:repeat(${TL_SLOTS},1fr);width:48px;flex-shrink:0;border-right:1px solid var(--borda);">`;
  for (let s = 0; s < TL_SLOTS; s++) {
    const h = TL_START + Math.floor(s/2), m = s%2===0?'00':'30';
    slotsHTML += `<div class="tl-slot-label ${m==='00'?'tl-hour':'tl-half'}" style="grid-row:${s+1};">${m==='00'?String(h).padStart(2,'0')+':00':''}</div>`;
  }
  slotsHTML += '</div>';

  const TIPO_BG = {'reuniao-online':'#A8C8F0','reuniao-presencial':'#FBBF8A','visita-tecnica':'#FDE68A','dedicacao-formatt':'#A8D5B0'};
  const TIPO_BD = {'reuniao-online':'#7AAEE0','reuniao-presencial':'#F0A060','visita-tecnica':'#F0CC50','dedicacao-formatt':'#78B888'};
  function getColor(tipo, prop) {
    const base = prop==='bg' ? TIPO_BG : TIPO_BD;
    if (base[tipo]) return base[tipo];
    const ct = loadCustomTipos().find(t=>t.id===tipo);
    return ct ? (prop==='bg'?ct.color:ct.border) : '#E0E0E0';
  }
  function timeToSlot(t) { const [h,m]=t.split(':').map(Number); return (h-TL_START)*2+(m>=30?1:0); }
  function computeColumns(dayEvs) {
    const layouts = dayEvs.map(e => {
      const s = timeToSlot(e.hora); if (s<0||s>=TL_SLOTS) return null;
      let end = s+1;
      if(e.horaFim){const es=timeToSlot(e.horaFim);if(es>s)end=Math.min(es,TL_SLOTS);}
      return {e,s,end,col:0,total:1};
    }).filter(Boolean);
    layouts.forEach((ev,i)=>{
      const overlaps=layouts.slice(0,i).filter(o=>o.s<ev.end&&o.end>ev.s);
      if(overlaps.length){const used=overlaps.map(o=>o.col);let col=0;while(used.includes(col))col++;ev.col=col;const maxTotal=Math.max(...overlaps.map(o=>o.total),col+1);ev.total=maxTotal;overlaps.forEach(o=>{if(o.total<maxTotal)o.total=maxTotal;});}
    });
    return layouts;
  }

  dates.forEach(ds => {
    const d = new Date(ds+'T12:00');
    const isToday = d.toDateString()===today.toDateString();
    const dayEvents = events.filter(e=>e.data===ds&&e.hora);
    const layouts = computeColumns(dayEvents);
    slotsHTML += `<div class="tl-day-col${isToday?' tl-today-col':''}" style="display:grid;grid-template-rows:repeat(${TL_SLOTS},1fr);position:relative;">`;
    for(let s=0;s<TL_SLOTS;s++){
      const h=TL_START+Math.floor(s/2),m=s%2===0?'00':'30',ts=String(h).padStart(2,'0')+':'+m;
      slotsHTML+=`<div class="tl-slot ${m==='00'?'tl-slot-hour':'tl-slot-half'}" style="grid-row:${s+1};" onclick="quickAddEvent('${ds}','${ts}')"></div>`;
    }
    layouts.forEach(({e,s:startSlot,end:endSlot,col:evCol,total})=>{
      const span=endSlot-startSlot;
      const topPct=(startSlot/TL_SLOTS*100).toFixed(2);
      const hPct=(span/TL_SLOTS*100).toFixed(2);
      const leftPct=(evCol/total*100).toFixed(2);
      const widPct=(1/total*100).toFixed(2);
      slotsHTML+=`<div class="tl-event-abs" style="position:absolute;top:${topPct}%;height:${hPct}%;left:calc(${leftPct}% + 1px);width:calc(${widPct}% - 3px);background:${getColor(e.tipo,'bg')};border-left:3px solid ${getColor(e.tipo,'border')};z-index:2;cursor:pointer;" onclick="event.stopPropagation();openEditEventModal(${e.id})"><span class="tl-event-time">${e.hora}${e.horaFim?'–'+e.horaFim:''}</span><span class="tl-event-title">${e.titulo}</span></div>`;
    });
    slotsHTML+='</div>';
  });
  slotsHTML+='</div>';
  return headerHTML+`<div class="tl-scroll-wrap">${slotsHTML}</div>`;
}

/* ── START ── */
initCalendar();

