<script>
const PROJ_KEY='fa-projetos-v1', RECEBER_KEY='fa-fin-receber', PAGAR_KEY='fa-fin-pagar', SALDO_KEY='fa-fin-saldo';
let periodoMeses=6;
function getProjetos(){try{return JSON.parse(localStorage.getItem(PROJ_KEY)||'[]');}catch{return[];}}
function getReceber() {try{return JSON.parse(localStorage.getItem(RECEBER_KEY)||'[]');}catch{return[];}}
function getPagar()   {try{return JSON.parse(localStorage.getItem(PAGAR_KEY)||'[]');}catch{return[];}}
const MESES_LABEL=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
const ORIGEM_LABEL={indicacao:'Indicação',instagram:'Instagram',site:'Site/Google',whatsapp:'WhatsApp',outro:'Outro'};

function fmtShort(v){const n=Number(v||0);if(n>=1000000)return'R$'+(n/1000000).toFixed(1)+'M';if(n>=1000)return'R$'+(n/1000).toFixed(0)+'k';return'R$'+n.toLocaleString('pt-BR');}
function fmtFull(v){return'R$\u00a0'+Number(v||0).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});}

function setPeriodo(n,btn){
  periodoMeses=n;
  document.querySelectorAll('.periodo-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderMetricas();
}

function getMeses(n){
  const now=new Date(), meses=[];
  for(let i=n-1;i>=0;i--){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    meses.push({
      key:d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0'),
      label:MESES_LABEL[d.getMonth()]+(n>6?'/'+String(d.getFullYear()).slice(2):''),
    });
  }
  return meses;
}

function renderMetricas(){
  const meses=getMeses(periodoMeses);
  const keys=new Set(meses.map(m=>m.key));
  const projetos=getProjetos(), receber=getReceber(), pagar=getPagar();

  // Faturamento por mês
  const fatPorMes=meses.map(m=>{
    const rec=receber.filter(r=>r.data&&r.data.startsWith(m.key)&&r.status==='recebido').reduce((s,r)=>s+(r.valor||0),0);
    const fin=projetos.filter(p=>p.status==='finalizados'&&p.entrega&&p.entrega.startsWith(m.key)).reduce((s,p)=>s+(p.valor||0),0);
    return rec+fin;
  });
  const despPorMes=meses.map(m=>pagar.filter(p=>p.data&&p.data.startsWith(m.key)&&p.status==='pago').reduce((s,p)=>s+(p.valor||0),0));

  const totalFat=fatPorMes.reduce((a,b)=>a+b,0);
  const totalDesp=despPorMes.reduce((a,b)=>a+b,0);
  const lucro=totalFat-totalDesp;

  // Ticket médio
  const projPeriodo=projetos.filter(p=>p.entrega&&keys.has(p.entrega.substring(0,7))&&p.status==='finalizados');
  const ticketMed=projPeriodo.length?totalFat/projPeriodo.length:0;

  // MoM
  const fatAtual=fatPorMes[fatPorMes.length-1]||0;
  const fatAnt=fatPorMes[fatPorMes.length-2]||0;
  const mom=fatAnt>0?((fatAtual-fatAnt)/fatAnt*100):0;

  // Crescimento período
  const metade=Math.floor(periodoMeses/2);
  const fatPrim=fatPorMes.slice(0,metade).reduce((a,b)=>a+b,0);
  const fatSeg=fatPorMes.slice(metade).reduce((a,b)=>a+b,0);
  const cresc=fatPrim>0?((fatSeg-fatPrim)/fatPrim*100):0;

  // Clientes
  const clienteMap={};
  projetos.forEach(p=>{
    if(!clienteMap[p.cliente])clienteMap[p.cliente]={nome:p.cliente,projetos:0,valor:0,tipos:new Set()};
    clienteMap[p.cliente].projetos++;
    clienteMap[p.cliente].valor+=(p.valor||0);
    (Array.isArray(p.tipo)?p.tipo:[p.tipo]).forEach(t=>t&&clienteMap[p.cliente].tipos.add(t));
  });
  const clientes=Object.values(clienteMap);
  const ativos=new Set(projetos.filter(p=>p.status==='andamento').map(p=>p.cliente)).size;
  const retornantes=clientes.filter(c=>c.projetos>1).length;
  const taxaRet=clientes.length?Math.round(retornantes/clientes.length*100):0;
  const topClientes=clientes.sort((a,b)=>b.valor-a.valor).slice(0,5);

  // Origens
  const origemMap={};
  projetos.filter(p=>p.origem).forEach(p=>{origemMap[p.origem]=(origemMap[p.origem]||0)+1;});
  const origens=Object.entries(origemMap).sort((a,b)=>b[1]-a[1]);
  const maxOrig=origens.length?origens[0][1]:1;

  // Tipos de serviço
  const tipoMap={};
  projetos.forEach(p=>(Array.isArray(p.tipo)?p.tipo:[p.tipo]).forEach(t=>{if(t)tipoMap[t]=(tipoMap[t]||0)+1;}));
