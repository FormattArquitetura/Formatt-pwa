  metas.forEach(m => {
    if (m.status !== 'concluida' && m.status !== 'pausada' && m.prazo) {
      const p = new Date(m.prazo + 'T12:00');
      if (p < hoje) m.status = 'atrasada';
    }
  });
  saveMetas(metas);

  // Resumo
  document.getElementById('res-total').textContent      = metas.length;
  document.getElementById('res-concluidas').textContent = metas.filter(m => m.status === 'concluida').length;
  document.getElementById('res-atrasadas').textContent  = metas.filter(m => m.status === 'atrasada').length;

  // Filtro
  const filtradas = filtroAtivo === 'todas'
    ? metas
    : metas.filter(m => m.status === filtroAtivo);

  const wrap = document.getElementById('plan-list');

  if (!filtradas.length) {
    wrap.innerHTML = `
      <div class="plan-empty">
        <div class="plan-empty-icon">🎯</div>
        <div class="plan-empty-title">${filtroAtivo === 'todas' ? 'Nenhuma meta ainda' : 'Nenhuma meta nesta categoria'}</div>
        <div class="plan-empty-sub">${filtroAtivo === 'todas' ? 'Clique em + para criar sua primeira meta' : 'Tente outro filtro'}</div>
        ${filtroAtivo === 'todas' ? `<button class="save-btn" style="max-width:220px;margin:0 auto;" onclick="openNovaMeta()">+ Criar meta</button>` : ''}
      </div>`;
    return;
  }

  // Ordena: atrasadas primeiro, depois por prazo
  const ordenadas = [...filtradas].sort((a, b) => {
    const prioridade = { atrasada: 0, andamento: 1, pausada: 2, concluida: 3 };
    if (prioridade[a.status] !== prioridade[b.status])
      return prioridade[a.status] - prioridade[b.status];
    if (!a.prazo) return 1;
    if (!b.prazo) return -1;
    return a.prazo.localeCompare(b.prazo);
  });

  wrap.innerHTML = ordenadas.map(m => renderMetaCard(m, hoje)).join('');
}

function renderMetaCard(m, hoje) {
  const etapas  = m.etapas || [];
  const feitas  = etapas.filter(e => e.feita).length;
  const total   = etapas.length;
  const pct     = total > 0 ? Math.round(feitas / total * 100) : 0;
  const cor     = m.cor || '#3B5436';

  // Dias para o prazo
  let prazoTxt  = '', prazoClass = '';
  if (m.prazo) {
    const p    = new Date(m.prazo + 'T12:00');
    const diff = Math.round((p - hoje) / 86400000);
    if (m.status === 'concluida') {
      prazoTxt = 'Concluída · prazo era ' + fmtDate(m.prazo);
    } else if (diff < 0) {
      prazoTxt  = `Atrasada ${Math.abs(diff)} dia${Math.abs(diff) > 1 ? 's' : ''}`;
      prazoClass = 'urgente';
    } else if (diff === 0) {
      prazoTxt = 'Vence hoje!'; prazoClass = 'urgente';
    } else if (diff <= 7) {
      prazoTxt = `Vence em ${diff} dia${diff > 1 ? 's' : ''}`; prazoClass = 'urgente';
    } else {
      prazoTxt = 'Prazo: ' + fmtDate(m.prazo);
    }
  }

  // Badge
  const badges = {
    andamento: ['badge-andamento', 'Em andamento'],
    atrasada:  ['badge-atrasada',  'Atrasada'],
    concluida: ['badge-concluida', 'Concluída'],
    pausada:   ['badge-pausada',   'Pausada'],
  };
  const [badgeCls, badgeTxt] = badges[m.status] || badges.andamento;

  // Preview etapas (máx 4)
  const previewEtapas = etapas.slice(0, 4).map(e =>
    `<span class="etapa-chip ${e.feita ? 'done' : ''}">${e.nome}</span>`
  ).join('');
  const extraEtapas = etapas.length > 4
    ? `<span class="etapa-chip">+${etapas.length - 4}</span>` : '';

  return `
    <div class="meta-card ${m.status === 'concluida' ? 'concluida' : ''}"
         onclick="openEditMeta(${m.id})">
      <div class="meta-card-accent" style="background:${cor};"></div>
      <div class="meta-header">
        <div class="meta-titulo">${m.titulo}</div>
        <span class="meta-badge ${badgeCls}">${badgeTxt}</span>
      </div>
      ${prazoTxt ? `<div class="meta-prazo ${prazoClass}">📅 ${prazoTxt}</div>` : ''}
      ${total > 0 ? `
        <div class="meta-prog-header">
          <span>${feitas} de ${total} etapa${total > 1 ? 's' : ''}</span>
          <span class="meta-prog-pct">${pct}%</span>
        </div>
        <div class="meta-prog-bar">
          <div class="meta-prog-fill" style="width:${pct}%;background:${cor};"></div>
        </div>` : ''}
      ${etapas.length ? `<div class="meta-etapas-preview">${previewEtapas}${extraEtapas}</div>` : ''}
    </div>`;
}

/* ── FILTRO ── */
function setFiltro(f, btn) {
  filtroAtivo = f;
  document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderMetas();
}

/* ── MODAL NOVA META ── */
function openNovaMeta() {
  editingMetaId = null;
  document.getElementById('mf-titulo').value  = '';
  document.getElementById('mf-desc').value    = '';
  document.getElementById('mf-prazo').value   = '';
  document.getElementById('mf-status').value  = 'andamento';
  document.getElementById('modal-delete-btn').style.display = 'none';
  document.getElementById('modal-title').textContent = 'Nova Meta';
  selectCorById('#3B5436');
  renderEtapasModal([]);
  document.getElementById('meta-modal').classList.add('open');
  setTimeout(() => document.getElementById('mf-titulo').focus(), 100);
}

function openEditMeta(id) {
  const m = loadMetas().find(x => x.id === id);
  if (!m) return;
  editingMetaId = id;
  document.getElementById('mf-titulo').value  = m.titulo;
  document.getElementById('mf-desc').value    = m.desc || '';
  document.getElementById('mf-prazo').value   = m.prazo || '';
  document.getElementById('mf-status').value  = m.status === 'atrasada' ? 'andamento' : m.status;
  document.getElementById('modal-delete-btn').style.display = 'block';
  document.getElementById('modal-title').textContent = m.titulo;
  selectCorById(m.cor || '#3B5436');
  renderEtapasModal(m.etapas || []);
  document.getElementById('meta-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('meta-modal').classList.remove('open');
}

/* ── COR ── */
function selectCor(el) {
  document.querySelectorAll('.cor-swatch').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  corSelecionada = el.dataset.cor;
}
function selectCorById(cor) {
  corSelecionada = cor;
  let found = false;
  document.querySelectorAll('.cor-swatch').forEach(s => {
    s.classList.remove('selected');
    if (s.dataset.cor === cor) { s.classList.add('selected'); found = true; }
  });
  if (!found && document.querySelector('.cor-swatch'))
    document.querySelector('.cor-swatch').classList.add('selected');
}

/* ── ETAPAS NO MODAL ── */
let etapasTemp = [];

function renderEtapasModal(etapas) {
  etapasTemp = etapas.map(e => ({ ...e }));
  _redrawEtapas();
}

function _redrawEtapas() {
  const wrap = document.getElementById('modal-etapas-list');
  if (!etapasTemp.length) { wrap.innerHTML = ''; return; }
  wrap.innerHTML = etapasTemp.map((e, i) => `
    <div class="etapa-item">
      <div class="etapa-check ${e.feita ? 'done' : ''}"
           onclick="toggleEtapaModal(${i})"></div>
      <span class="etapa-nome ${e.feita ? 'done' : ''}">${e.nome}</span>
      <button class="etapa-remove" onclick="removeEtapaModal(${i})">×</button>
    </div>`).join('');
}

function toggleEtapaModal(i) {
  etapasTemp[i].feita = !etapasTemp[i].feita;
  _redrawEtapas();
}

function removeEtapaModal(i) {
  etapasTemp.splice(i, 1);
  _redrawEtapas();
}

function adicionarEtapa() {
  const input = document.getElementById('etapa-nova-input');
  const nome  = input.value.trim();
  if (!nome) { input.focus(); return; }
  etapasTemp.push({ id: Date.now(), nome, feita: false });
  input.value = '';
  _redrawEtapas();
  input.focus();
}

/* ── SALVAR ── */
function saveMeta() {
  const titulo = document.getElementById('mf-titulo').value.trim();
  if (!titulo) { alert('Informe o título da meta'); return; }

  const metas = loadMetas();
  const meta = {
    titulo,
    desc:   document.getElementById('mf-desc').value,
    prazo:  document.getElementById('mf-prazo').value,
    status: document.getElementById('mf-status').value,
    cor:    corSelecionada,
    etapas: etapasTemp,
  };

  if (editingMetaId !== null) {
    const idx = metas.findIndex(m => m.id === editingMetaId);
    if (idx !== -1) metas[idx] = { ...metas[idx], ...meta };
  } else {
    metas.push({ id: Date.now(), ...meta });
  }

  saveMetas(metas);
  closeModal();
  renderMetas();
}

function deleteMeta() {
  if (!editingMetaId || !confirm('Deletar esta meta?')) return;
  saveMetas(loadMetas().filter(m => m.id !== editingMetaId));
  closeModal();
  renderMetas();
}

/* ── UTILS ── */
function fmtDate(d) {
  if (!d) return '';
  return new Date(d + 'T12:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short', year:'2-digit'});
}

/* ── START ── */
renderMetas();

// Expõe funções no escopo global para os onclick do HTML
window.setFiltro        = setFiltro;
window.openNovaMeta     = openNovaMeta;
window.openEditMeta     = openEditMeta;
window.closeModal       = closeModal;
window.saveMeta         = saveMeta;
window.deleteMeta       = deleteMeta;
window.selectCor        = selectCor;
window.adicionarEtapa   = adicionarEtapa;
window.toggleEtapaModal = toggleEtapaModal;
window.removeEtapaModal = removeEtapaModal;
window._saveModal       = _saveModal;

})();
</script>


