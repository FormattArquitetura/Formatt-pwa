/* ── CONFIG ACTIONS ── */
function exportarDados() {
 const keys = ['fa-projetos-v1','fa-agenda-v1','fa-fin-receber','fa-fin-pagar','fa-fin-saldo','fa-metas-v1','fa-inst-empresa','fa-inst-equipe','fa-inst-docs','fa-inst-contatos','fa-inst-honorarios'];
 const data = {};
 keys.forEach(k => { try{ data[k] = JSON.parse(localStorage.getItem(k)||'null'); }catch{} });
 const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});
 const a = document.createElement('a');
 a.href = URL.createObjectURL(blob);
 a.download = 'formatt-backup-'+new Date().toISOString().split('T')[0]+'.json';
 a.click();
}

function importarDados() {
 const input = document.createElement('input');
 input.type = 'file'; input.accept = '.json';
 input.onchange = e => {
 const file = e.target.files[0]; if(!file) return;
 const reader = new FileReader();
 reader.onload = ev => {
 try {
 const data = JSON.parse(ev.target.result);
 if(!confirm('Isso vai substituir todos os dados atuais. Confirmar?')) return;
 Object.entries(data).forEach(([k,v]) => { if(v!==null) localStorage.setItem(k,JSON.stringify(v)); });
 alert('Dados importados com sucesso!');
 renderTab(tabAtiva);
 } catch { alert('Arquivo inválido.'); }
 };
 reader.readAsText(file);
 };
 input.click();
}

function limparDados() {
 if(!confirm('Tem certeza? Isso apaga TODOS os dados do app permanentemente.')) return;
 if(!confirm('Confirmação final: apagar tudo?')) return;
 const keys = ['fa-projetos-v1','fa-agenda-v1','fa-fin-receber','fa-fin-pagar','fa-fin-saldo','fa-fin-saldo-hist','fa-metas-v1','fa-inst-empresa','fa-inst-equipe','fa-inst-docs','fa-inst-contatos','fa-inst-honorarios','fa-custom-tipos'];
 keys.forEach(k => localStorage.removeItem(k));
 alert('Dados removidos. Recarregue o app.');
}

