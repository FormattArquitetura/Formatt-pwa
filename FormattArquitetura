<script>
/* ═══════════════════════════════════════════════
   FINANCEIRO — módulo standalone
   localStorage keys:
     fa-fin-saldo     → number
     fa-fin-receber   → array (manuais)
     fa-fin-pagar     → array (fixos + avulsos)
═══════════════════════════════════════════════ */

const SALDO_KEY   = 'fa-fin-saldo';
const RECEBER_KEY = 'fa-fin-receber';
const PAGAR_KEY   = 'fa-fin-pagar';
const PROJ_KEY    = 'fa-projetos-v1';

let editingFinId   = null;
let editingFinType = null;

/* ── STORAGE ── */
function getSaldo()   { return parseFloat(localStorage.getItem(SALDO_KEY) || '0'); }
function getReceber() { try { return JSON.parse(localStorage.getItem(RECEBER_KEY) || '[]'); } catch { return []; } }
function getPagar()   { try { return JSON.parse(localStorage.getItem(PAGAR_KEY) || '[]'); } catch { return []; } }
function getProjetos(){ try { return JSON.parse(localStorage.getItem(PROJ_KEY)    || '[]'); } catch { return []; } }

function saveSaldoData(v) { localStorage.setItem(SALDO_KEY, v); }
function saveReceber(d)   { localStorage.setItem(RECEBER_KEY, JSON.stringify(d)); }
function savePagar(d)     { localStorage.setItem(PAGAR_KEY,   JSON.stringify(d)); }

/* ── SEED (primeira abertura) ── */
(function() {
  if (!localStorage.getItem(RECEBER_KEY)) {
    saveReceber([
      { id: 1001, desc: 'Honorários Ana Paula Lima — parcela 1', valor: 6000, data: '2025-06-10', tipo: 'receber-manual', categoria: 'honorarios', status: 'recebido', obs: '' },
      { id: 1002, desc: 'Honorários Marcos Braga — parcela 1',   valor: 3167, data: '2025-06-20', tipo: 'receber-manual', categoria: 'honorarios', status: 'pendente', obs: '' },
    ]);
  }
  if (!localStorage.getItem(PAGAR_KEY)) {
    savePagar([
      { id: 2001, desc: 'Aluguel do escritório',  valor: 2200, data: '2025-06-05', tipo: 'pagar-fixo', categoria: 'aluguel',    recorrencia: 'mensal', status: 'pago',     obs: '' },
      { id: 2002, desc: 'Adobe Creative Cloud',   valor: 349,  data: '2025-06-15', tipo: 'pagar-fixo', categoria: 'software',   recorrencia: 'mensal', status: 'pendente', obs: '' },
      { id: 2003, desc: 'Impressão de pranchas',  valor: 420,  data: '2025-06-18', tipo: 'pagar-avulso', categoria: 'fornecedor', recorrencia: '', status: 'pendente', obs: 'Projeto Horizonte' },
    ]);
  }
})();

/* ── FORMATAÇÃO ── */
const fmtVal  = v => 'R$ ' + Number(v || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
const fmtDate = d => d ? new Date(d + 'T12:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short', year:'2-digit'}) : '—';

/* ── TABS ── */
function switchFinTab(tab, btn) {
  document.querySelectorAll('.fin-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.fin-section').forEach(s => s.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('sec-' + tab).classList.add('active');
  if (tab === 'espectro') renderEspectro();
  if (tab === 'caixa')    renderCaixa();
  if (tab === 'receber')  renderReceber();
  if (tab === 'pagar')    renderPagar();
  // Redraw chart para a aba ativa
  setTimeout(() => {
    if (tab === 'espectro') renderChartEspectro();
    if (tab === 'caixa')    renderChartCaixa();
    if (tab === 'receber')  renderChartReceber();
    if (tab === 'pagar')    renderChartPagar();
  }, 30);
}

/* ── RENDER ALL ── */
function renderAll() {
  renderEspectro();
  renderCaixa();
  renderReceber();
  renderPagar();
  // Gráficos com delay para garantir layout pronto
  setTimeout(() => {
    renderChartEspectro();
    renderChartCaixa();
    renderChartReceber();
    renderChartPagar();
  }, 50);
}

/* ══ CAIXA ══ */
function renderCaixa() {
  const saldo = getSaldo();
  document.getElementById('caixa-valor-display').textContent = fmtVal(saldo);

  // Projeção mensal
  renderProjecaoCaixa(saldo);

  // Histórico
  const hist = JSON.parse(localStorage.getItem('fa-fin-saldo-hist') || '[]');
  const wrap = document.getElementById('caixa-historico');
  if (!hist.length) {
    wrap.innerHTML = '<div class="fin-empty">Nenhuma atualização registrada ainda.</div>';
    return;
  }
  wrap.innerHTML = hist.slice(-5).reverse().map(h => `
    <div class="fin-item" style="cursor:default;">
