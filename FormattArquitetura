.cor-swatch {
  width: 28px; height: 28px; border-radius: 50%;
  cursor: pointer; border: 2px solid transparent;
  transition: transform .15s, border-color .15s;
}
.cor-swatch:hover { transform: scale(1.15); }
.cor-swatch.selected { transform: scale(1.2); border-color: var(--ink) !important; }

/* ── ETAPAS NO MODAL ── */
.etapas-list { display: flex; flex-direction: column; gap: 6px; }
.etapa-item {
  display: flex; align-items: center; gap: 10px;
