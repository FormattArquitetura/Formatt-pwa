}
function closeCalModal(e) {
  if (e.target === document.getElementById('cal-modal')) document.getElementById('cal-modal').classList.remove('open');
}
function saveCalEvent() {
  const tipoSel = document.getElementById('cf-tipo').value;
  if (tipoSel === 'outro') {
    const nome = document.getElementById('cf-custom-nome').value.trim();
    if (!nome) { alert('Informe o nome do novo tipo'); return; }
    const id = 'custom-' + nome.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    const novoTipo = { id, nome, color: selectedCustomColor, border: selectedCustomBorder };
    const tipos = loadCustomTipos();
    if (!tipos.find(t => t.id === id)) { tipos.push(novoTipo); saveCustomTipos(tipos); addCustomTipoToSidebar(novoTipo); }
    document.getElementById('cf-tipo').value = id;
  }
  const titulo = document.getElementById('cf-titulo').value.trim();
  if (!titulo) { alert('Informe o título'); return; }
  const events = loadEvents();
  events.push({
    id: Date.now(), titulo,
    tipo: document.getElementById('cf-tipo').value,
    data: document.getElementById('cf-data').value,
    hora: document.getElementById('cf-hora').value,
    horaFim: document.getElementById('cf-hora-fim').value,
    local: document.getElementById('cf-local').value,
    obs: document.getElementById('cf-obs').value,
  });
  saveEvents(events);
  document.getElementById('cal-modal').classList.remove('open');
  document.getElementById('cf-custom-fields').style.display = 'none';
  renderCalendar();
}

/* ── MODAL EDITAR EVENTO ── */
function openEditEventModal(eventId) {
  const ev = loadEvents().find(e => e.id === eventId);
  if (!ev) return;
  editingEventId = eventId;
  const sel = document.getElementById('ef-tipo');
  loadCustomTipos().forEach(t => {
    if (!sel.querySelector('option[value="'+t.id+'"]')) {
      const opt = document.createElement('option');
      opt.value = t.id; opt.textContent = t.nome;
      sel.appendChild(opt);
    }
  });
  document.getElementById('ef-id').value = ev.id;
  document.getElementById('ef-titulo').value = ev.titulo || '';
  document.getElementById('ef-tipo').value = ev.tipo || 'reuniao-online';
  document.getElementById('ef-data').value = ev.data || '';
  document.getElementById('ef-hora').value = ev.hora || '';
  document.getElementById('ef-hora-fim').value = ev.horaFim || '';
  document.getElementById('ef-local').value = ev.local || '';
  document.getElementById('ef-obs').value = ev.obs || '';
  document.getElementById('edit-modal-title').textContent = ev.titulo;
  document.getElementById('edit-modal').classList.add('open');
}
function saveEditCalEvent() {
  const titulo = document.getElementById('ef-titulo').value.trim();
  if (!titulo) { alert('Informe o título'); return; }
  const events = loadEvents();
  const idx = events.findIndex(e => e.id === editingEventId);
  if (idx === -1) return;
  events[idx] = {
    ...events[idx], titulo,
    tipo: document.getElementById('ef-tipo').value,
    data: document.getElementById('ef-data').value,
    hora: document.getElementById('ef-hora').value,
    horaFim: document.getElementById('ef-hora-fim').value,
    local: document.getElementById('ef-local').value,
    obs: document.getElementById('ef-obs').value,
  };
  saveEvents(events);
  document.getElementById('edit-modal').classList.remove('open');
  renderCalendar();
}
function deleteCalEvent() {
  if (!confirm('Deletar este compromisso?')) return;
  saveEvents(loadEvents().filter(e => e.id !== editingEventId));
  document.getElementById('edit-modal').classList.remove('open');
  renderCalendar();
}

/* ── CUSTOM TIPO ── */
function onTipoChange(sel) {
  document.getElementById('cf-custom-fields').style.display = sel.value === 'outro' ? 'block' : 'none';
}
function selectColor(el) {
  document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
