<!-- Firebase SDK -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getFirestore, doc, setDoc, getDoc, onSnapshot, collection } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
  import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

  const firebaseConfig = {
    apiKey: "AIzaSyAqlWI61MEPO9PgkIOuRsTQO9Nu5VN61dQ",
    authDomain: "formatt-arquitetura.firebaseapp.com",
    projectId: "formatt-arquitetura",
    storageBucket: "formatt-arquitetura.firebasestorage.app",
    messagingSenderId: "836831404092",
    appId: "1:836831404092:web:9d8deb0986b90be3852339",
    measurementId: "G-LY47GJ8Z11"
  };

  const app = initializeApp(firebaseConfig);
  const db = getFirestore(app);
  const auth = getAuth(app);

  // Chaves que serão sincronizadas com o Firestore
  const SYNC_KEYS = [
    'fa-agenda-v1',
    'fa-custom-tipos',
    'fa-projetos-v1',
    'fa-fin-saldo',
    'fa-fin-saldo-hist',
    'fa-fin-receber',
    'fa-fin-pagar',
    'fa-metas-v1',
    'fa-inst-empresa',
    'fa-inst-equipe',
    'fa-inst-docs',
    'fa-inst-contatos',
    'fa-inst-honorarios',
    'fa-inst-ferramentas'
  ];

  // ID do usuário Formatt (fixo, pois é uso pessoal)
  const USER_DOC = 'fernanda-formatt';

  let syncEnabled = false;
  let userId = null;

  // Salva todos os dados no Firestore
  async function pushAllToFirestore() {
    if (!syncEnabled || !userId) return;
    try {
      const data = {};
      SYNC_KEYS.forEach(k => {
        const val = localStorage.getItem(k);
        if (val !== null) data[k] = val;
      });
      data._updatedAt = new Date().toISOString();
      data._userId = userId;
      await setDoc(doc(db, 'formatt-data', USER_DOC), data, { merge: true });
      console.log('[Formatt Firebase] ✅ Dados salvos na nuvem');
    } catch(e) {
      console.warn('[Formatt Firebase] Erro ao salvar:', e);
    }
  }

  // Carrega dados do Firestore para o localStorage
  async function pullFromFirestore() {
    try {
      const snap = await getDoc(doc(db, 'formatt-data', USER_DOC));
      if (snap.exists()) {
        const data = snap.data();
        let restored = 0;
        SYNC_KEYS.forEach(k => {
          if (data[k] !== undefined) {
            localStorage.setItem(k, data[k]);
            restored++;
          }
        });
        if (restored > 0) {
          console.log('[Formatt Firebase] ✅ ' + restored + ' chaves restauradas da nuvem');
          return true;
        }
      } else {
        console.log('[Formatt Firebase] Nenhum dado na nuvem ainda. Primeiro uso!');
      }
    } catch(e) {
      console.warn('[Formatt Firebase] Erro ao carregar:', e);
    }
    return false;
  }

  // Intercepta o localStorage para sincronizar automaticamente
  function patchLocalStorage() {
    const origSetItem = localStorage.setItem.bind(localStorage);
    localStorage.setItem = function(key, value) {
      origSetItem(key, value);
      if (syncEnabled && SYNC_KEYS.includes(key)) {
        // Debounce: aguarda 1.5s após última alteração antes de enviar
        clearTimeout(window._fbSyncTimer);
        window._fbSyncTimer = setTimeout(pushAllToFirestore, 1500);
      }
    };
  }

  // Expõe funções globais para uso no app
  window.FormattFirebase = {
    pushAll: pushAllToFirestore,
    pull: pullFromFirestore,
    isEnabled: () => syncEnabled
  };

  // Inicializa autenticação e sincronização
  signInAnonymously(auth).then(() => {
    console.log('[Formatt Firebase] Autenticação anônima OK');
  }).catch(e => {
    console.warn('[Formatt Firebase] Auth falhou:', e);
  });

  onAuthStateChanged(auth, async (user) => {
    if (user) {
      userId = user.uid;
      console.log('[Formatt Firebase] UID:', userId);

      // Tenta restaurar dados da nuvem antes de renderizar
      const hadData = await pullFromFirestore();
      syncEnabled = true;
      patchLocalStorage();



      if (hadData) {
        console.log('[Formatt Firebase] Dados da nuvem carregados com sucesso!');
        // Recarrega os módulos se já estiverem abertos
        if (window.renderTab) window.renderTab(window.tabAtiva || 'projetos');
        if (window.renderEmpresa) window.renderEmpresa();
      }
    }
  });
</script>
