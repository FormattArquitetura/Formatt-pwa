function closeNewProject(e) {
  if (e.target === document.getElementById('proj-modal')) {
    document.getElementById('proj-modal').classList.remove('open');
  }
}

/* ── MODAL EDITAR ── */
function editProject(id) {
  const p = loadProjects().find(x => x.id === id);
  if (!p) return;
  editingId = id;

  const isCap = p.status === 'captacao' || p.status === 'nao-contratado';
  const isAnd = p.status === 'andamento';

  document.getElementById('pf-cliente').value   = p.cliente;
  clearTipos();
  setTipos(Array.isArray(p.tipo) ? p.tipo : (p.tipo ? [p.tipo] : []));
  document.getElementById('pf-status').value     = p.status;
  document.getElementById('pf-obs').value        = p.obs || '';
  document.getElementById('fields-projeto').style.display   = isCap ? 'none' : 'block';
  document.getElementById('fields-captacao').style.display  = isCap ? 'block' : 'none';
  document.getElementById('fields-checklist').style.display = isAnd ? 'block' : 'none';

  if (isCap) {
    document.getElementById('pf-valor-cap').value = p.valorCap || '';
    document.getElementById('pf-prazo').value     = p.prazo    || '';
    document.getElementById('pf-origem').value    = p.origem   || '';
  } else {
    document.getElementById('pf-valor').value   = p.valor   || '';
    document.getElementById('pf-perc').value    = p.perc    || 0;
    document.getElementById('pf-inicio').value  = p.inicio  || '';
    document.getElementById('pf-entrega').value = p.entrega || '';
  }

  // Monta checklist se em andamento
  if (isAnd) renderChecklist(p);

  document.getElementById('proj-modal-title').textContent  = p.cliente;
  document.getElementById('proj-delete-btn').style.display = 'block';
  document.getElementById('proj-save-btn').textContent     = '✓ Salvar alterações';
  document.getElementById('proj-modal').classList.add('open');
}

/* ── CHECKLIST ── */
function renderChecklist(p) {
  const tipos  = Array.isArray(p.tipo) ? p.tipo : (p.tipo ? [p.tipo] : []);
  const feitos = Array.isArray(p.tipoFeito) ? p.tipoFeito : [];
  const wrap   = document.getElementById('pf-checklist');

  if (!tipos.length) {
    wrap.innerHTML = '<div style="font-size:12px;color:var(--muted);">Nenhum serviço selecionado.</div>';
    return;
  }

  const pct = Math.round(feitos.length / tipos.length * 100);

  wrap.innerHTML = tipos.map(t => `
    <div class="check-item ${feitos.includes(t) ? 'done' : ''}"
         data-tipo="${encodeURIComponent(t)}"
         onclick="toggleCheck(this)">
      <div class="check-box"></div>
      <span class="check-label">${t}</span>
    </div>
  `).join('') + `<div class="check-perc" id="check-perc-label">${feitos.length} de ${tipos.length} concluído${feitos.length !== 1 ? 's' : ''} — ${pct}%</div>`;
}

function toggleCheck(el) {
  const tipo     = decodeURIComponent(el.dataset.tipo);
  const projects = loadProjects();
  const idx      = projects.findIndex(p => p.id === editingId);
  if (idx === -1) return;

  const p      = projects[idx];
  const tipos  = Array.isArray(p.tipo) ? p.tipo : [];
  let feitos   = Array.isArray(p.tipoFeito) ? [...p.tipoFeito] : [];

  if (feitos.includes(tipo)) {
    feitos = feitos.filter(t => t !== tipo);
    el.classList.remove('done');
  } else {
    feitos.push(tipo);
    el.classList.add('done');
  }

  // Recalcula % e salva imediatamente
  const pct = tipos.length > 0 ? Math.round(feitos.length / tipos.length * 100) : 0;
  projects[idx].tipoFeito = feitos;
  projects[idx].perc      = pct;
  saveProjects(projects);

  // Atualiza o contador
  const label = document.getElementById('check-perc-label');
  if (label) label.textContent = `${feitos.length} de ${tipos.length} concluído${feitos.length !== 1 ? 's' : ''} — ${pct}%`;

  // Atualiza o campo % no formulário
  const percEl = document.getElementById('pf-perc');
  if (percEl) percEl.value = pct;

  renderProjects();
}

/* ── SALVAR ── */
function saveProject() {
  const cliente = document.getElementById('pf-cliente').value.trim();
  if (!cliente) { alert('Informe o nome do cliente'); return; }

  const status = document.getElementById('pf-status').value;
  const isCap  = status === 'captacao' || status === 'nao-contratado';

  const base = {
    cliente,
    tipo:   getTipos(),
    status,
    obs:    document.getElementById('pf-obs').value,
  };

  const extra = isCap ? {
    valorCap: Number(document.getElementById('pf-valor-cap').value) || 0,
    prazo:    document.getElementById('pf-prazo').value,
    origem:   document.getElementById('pf-origem').value,
    // limpar campos de projeto
    valor: 0, perc: 0, inicio: '', entrega: '',
  } : {
    valor:   Number(document.getElementById('pf-valor').value) || 0,
    perc:    Number(document.getElementById('pf-perc').value)  || 0,
    inicio:  document.getElementById('pf-inicio').value,
    entrega: document.getElementById('pf-entrega').value,
    // limpar campos de captação
    valorCap: 0, prazo: '', origem: '',
  };

  const projects = loadProjects();
  if (editingId !== null) {
    const idx = projects.findIndex(p => p.id === editingId);
    if (idx !== -1) projects[idx] = { ...projects[idx], ...base, ...extra };
  } else {
    projects.push({ id: Date.now(), ...base, ...extra, tipoFeito: [] });
  }

  saveProjects(projects);
  document.getElementById('proj-modal').classList.remove('open');
  renderProjects();

  // Ir para a aba correta (não-contratado vai para Todos)
  const destino = status === 'nao-contratado' ? 'todos' : status;
  const btn = document.querySelector(`.proj-tab[onclick*="'${destino}'"]`);
  if (btn) switchTab(destino, btn);
}

/* ── DELETAR ── */
function deleteProject() {
  if (!editingId || !confirm('Deletar este registro?')) return;
  saveProjects(loadProjects().filter(p => p.id !== editingId));
  document.getElementById('proj-modal').classList.remove('open');
  renderProjects();
}

/* ── CHIPS DE TIPO DE SERVIÇO ── */
const TIPOS_FIXOS = [
  'Projeto Arquitetônico','Planta Baixa','Projeto Executivo',
  'Interiores','Ilustração 3D','Fachada','Paisagismo','Projeto Legal'
];

function getTipos() {
  // Retorna array de strings com os tipos selecionados
  return Array.from(document.querySelectorAll('.tipo-chip.selected'))
    .map(c => c.dataset.tipo)
    .filter(t => t && t !== '__outros__');
}

function clearTipos() {
  // Desmarca todos os chips e remove chips customizados
  document.querySelectorAll('.tipo-chip').forEach(c => c.classList.remove('selected'));
  document.querySelectorAll('.tipo-chip-custom').forEach(c => c.remove());
  document.getElementById('tipo-outro-wrap').style.display = 'none';
  document.getElementById('tipo-outro-input').value = '';
}

function setTipos(tipos) {
  if (!tipos || !tipos.length) return;
  tipos.forEach(tipo => {
    // Procura chip fixo
    const chip = document.querySelector(`.tipo-chip[data-tipo="${CSS.escape(tipo)}"]`);
    if (chip && tipo !== '__outros__') {
      chip.classList.add('selected');
    } else if (!TIPOS_FIXOS.includes(tipo) && tipo !== '__outros__') {
      // É um tipo customizado — cria o chip
      _addCustomChip(tipo, true);
    }
  });
}

function toggleTipo(btn) {
  btn.classList.toggle('selected');
}

function toggleOutros(btn) {
  const wrap = document.getElementById('tipo-outro-wrap');
  const visible = wrap.style.display === 'flex';
  wrap.style.display = visible ? 'none' : 'flex';
  btn.classList.toggle('selected', !visible);
  if (!visible) setTimeout(() => document.getElementById('tipo-outro-input').focus(), 50);
}

function addOutroTipo() {
  const input = document.getElementById('tipo-outro-input');
  const nome = input.value.trim();
  if (!nome) { input.focus(); return; }
  // Verifica duplicata
  const existe = document.querySelector(`.tipo-chip[data-tipo="${CSS.escape(nome)}"]`);
  if (existe) {
    existe.classList.add('selected');
  } else {
    _addCustomChip(nome, true);
  }
  input.value = '';
  // Fecha o campo mas mantém o botão Outros ativo enquanto há input aberto
}

function _addCustomChip(nome, selected) {
  const btn = document.querySelector('.tipo-chip-outros');
  const chip = document.createElement('button');
  chip.type = 'button';
  chip.className = 'tipo-chip tipo-chip-custom' + (selected ? ' selected' : '');
  chip.dataset.tipo = nome;
  chip.innerHTML = nome + '<span class="chip-remove" onclick="removeCustomChip(event,this)">✕</span>';
  chip.onclick = function(e) {
    if (!e.target.classList.contains('chip-remove')) toggleTipo(chip);
  };
  // Insere antes do botão Outros
  btn.parentNode.insertBefore(chip, btn);
}

function removeCustomChip(e, span) {
  e.stopPropagation();
  span.closest('.tipo-chip-custom').remove();
}

/* ── START ── */
renderProjects();
</script>

