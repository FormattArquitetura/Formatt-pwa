function renderProjecaoCaixa(saldoAtual) {
  const receber  = getReceber();
  const pagar    = getPagar();
  const projetos = getProjetos().filter(p => p.status === 'andamento' && p.valor > 0);
  const MESES_LABEL = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const N = 6; // próximos 6 meses
  const now = new Date();

  // Monta array de meses futuros (incluindo o mês atual)
  const meses = [];
  for (let i = 0; i < N; i++) {
    const d   = new Date(now.getFullYear(), now.getMonth() + i, 1);
    const key = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
    meses.push({ key, label: MESES_LABEL[d.getMonth()] + '/' + String(d.getFullYear()).slice(2), entradas: 0, saidas: 0 });
  }

  // Soma entradas por mês (a receber manuais pendentes)
  receber.filter(r => r.status !== 'recebido').forEach(r => {
    if (!r.data) return;
    const key = r.data.substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.entradas += (r.valor || 0);
  });

  // Soma entradas dos projetos (usa mês de entrega como referência)
  projetos.forEach(p => {
    const ref = p.entrega || '';
    if (!ref) return;
    const key = ref.substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.entradas += (p.valor || 0);
  });

  // Soma saídas por mês (a pagar pendentes)
  pagar.filter(p => p.status !== 'pago').forEach(p => {
    if (!p.data) return;
    const key = p.data.substring(0, 7);
    const m = meses.find(m => m.key === key);
    if (m) m.saidas += (p.valor || 0);
    // Despesas fixas mensais: propaga para os meses seguintes se recorrente
    if (p.tipo === 'pagar-fixo' && p.recorrencia === 'mensal') {
      meses.forEach(mes => {
        if (mes.key !== key) mes.saidas += (p.valor || 0);
      });
    }
  });

  // Calcula saldo acumulado mês a mês
  let saldoAcum = saldoAtual;
  const projList = document.getElementById('caixa-projecao-list');
  const now_key  = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');

  projList.innerHTML = meses.map((m, i) => {
    const delta   = m.entradas - m.saidas;
    if (i > 0) saldoAcum += delta;
    const isAtual = m.key === now_key;
    const pos     = saldoAcum >= 0;
    return `
      <div class="proj-mes-item ${pos ? 'positivo' : 'negativo'} ${isAtual ? 'proj-mes-atual' : ''}">
        <div class="proj-mes-nome">${m.label}${isAtual ? ' <span style="font-size:10px;color:var(--muted);font-weight:400;">· mês atual</span>' : ''}</div>
        <div class="proj-mes-saldo ${pos ? 'positivo' : 'negativo'}">${fmtVal(saldoAcum)}</div>
        <div class="proj-mes-detalhe">
          ${m.entradas ? `<span style="color:#4A7FA5;">▲ ${fmtVal(m.entradas)}</span>` : ''}
          ${m.entradas && m.saidas ? ' &nbsp;' : ''}
          ${m.saidas ? `<span style="color:#B05A3A;">▼ ${fmtVal(m.saidas)}</span>` : ''}
          ${!m.entradas && !m.saidas ? '<span>Sem lançamentos previstos</span>' : ''}
        </div>
      </div>`;
  }).join('');

  // Guarda dados para o gráfico
  window._projecaoData = { meses, saldoAtual };
}

