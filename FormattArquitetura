/* ══ FERRAMENTAS ══ */
const FERR_CAT_LABEL = { software:'Software', ia:'Inteligência Artificial', gestao:'Gestão & Produtividade', outro:'Outros' };
const FERR_CAT_ORDER = ['software','ia','gestao','outro'];

function renderFerramentas() {
 const lista = loadArr(KEYS.ferramentas);
 const el = document.getElementById('sec-ferramentas');

 // Agrupa por categoria
 const grupos = {};
 FERR_CAT_ORDER.forEach(c => grupos[c] = []);
 lista.forEach(f => {
 const cat = FERR_CAT_ORDER.includes(f.categoria) ? f.categoria : 'outro';
 grupos[cat].push(f);
 });

 let html = '';
 FERR_CAT_ORDER.forEach(cat => {
 const itens = grupos[cat];
 if (!itens.length) return;
 html += `<div class="ferr-categoria-title">${FERR_CAT_LABEL[cat]}</div>`;
 html += itens.map(f => `
 <div class="ferr-card ${cat}" onclick="editFerramenta(${f.id})">
 <div class="ferr-info">
 <div class="ferr-nome">${f.nome}</div>
 <div class="ferr-tipo">${f.tipo||''}</div>
 <div class="ferr-desc">${f.descricao||''}</div>
 ${f.plano?`<div style="font-size:11px;color:var(--verde);margin-top:4px;">Plano: ${f.plano}</div>`:''}
 </div>
 <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;">
 <span class="ferr-badge ${cat}">${FERR_CAT_LABEL[cat]}</span>
 ${f.link?`<a class="pessoa-action-btn" href="${f.link}" target="_blank" onclick="event.stopPropagation()">Link</a>`:''}
 </div>
 </div>`).join('');
 });

 if (!lista.length) html = `
 <div style="text-align:center;padding:48px 20px;">
 <div style="font-size:36px;margin-bottom:12px;"></div>
 <div style="font-family:'Cormorant Garamond',Georgia,serif;font-size:20px;color:var(--ink);margin-bottom:6px;">Nenhuma ferramenta cadastrada</div>
 <div style="font-size:13px;color:var(--muted);">Clique em + para adicionar</div>
 </div>`;

 el.innerHTML = html + `<button class="add-btn" style="margin-top:8px;" onclick="novaFerramenta()">+ Adicionar ferramenta</button>`;
}

function novaFerramenta() { _ferramentaModal(null); }
function editFerramenta(id) { _ferramentaModal(id); }
function _ferramentaModal(id) {
 const arr = loadArr(KEYS.ferramentas);
 const f = id ? arr.find(x=>x.id===id) : null;
 openModal(f?f.nome:'Nova ferramenta',
 `<div class="field"><label class="field-label">Nome</label>
 <input class="field-input" id="f-nome" value="${f?.nome||''}"></div>
 <div class="field"><label class="field-label">Categoria</label>
 <select class="field-input" id="f-cat">
 <option value="software" ${f?.categoria==='software'?'selected':''}>Software</option>
 <option value="ia" ${f?.categoria==='ia'?'selected':''}>Inteligência Artificial</option>
 <option value="gestao" ${f?.categoria==='gestao'?'selected':''}>Gestão & Produtividade</option>
 <option value="outro" ${f?.categoria==='outro'?'selected':''}>Outro</option>
 </select></div>
 <div class="field"><label class="field-label">Tipo / Função</label>
 <input class="field-input" id="f-tipo" value="${f?.tipo||''}" placeholder="Ex: Modelagem 3D, Geração de imagens"></div>
 <div class="field"><label class="field-label">Descrição</label>
 <textarea class="field-input field-textarea" id="f-desc" style="min-height:72px;">${f?.descricao||''}</textarea></div>
 <div class="field"><label class="field-label">Plano / Licença</label>
 <input class="field-input" id="f-plano" value="${f?.plano||''}" placeholder="Ex: Pro, Gratuito"></div>
 <div class="field"><label class="field-label">Link / Site</label>
 <input class="field-input" id="f-link" value="${f?.link||''}" placeholder="https://..."></div>
 <button class="save-btn" onclick="_saveModal()"> Salvar</button>`,
 () => {
 const arr = loadArr(KEYS.ferramentas);
 const obj = {
 nome: val('f-nome'),
 categoria: val('f-cat'),
 tipo: val('f-tipo'),
 descricao: val('f-desc'),
 plano: val('f-plano'),
 link: val('f-link'),
 };
 if (f) { const i=arr.findIndex(x=>x.id===id); arr[i]={...arr[i],...obj}; }
 else arr.push({id:Date.now(),...obj});
 save(KEYS.ferramentas, arr);
 closeModal(); renderFerramentas();
 },
 f ? ()=>{ save(KEYS.ferramentas, loadArr(KEYS.ferramentas).filter(x=>x.id!==id)); closeModal(); renderFerramentas(); } : null
 );
}

